// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 840
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    $set $r2 0 52719
    $set $r3 0 37035
    $set $r4 0 22136
    $set $r5 0 4660
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
;
||
    $st ($i64) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -16
    $set $r3 0 4369
    $set $r4 0 4369
    $set $r5 0 4369
    $set $r6 0 4369
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    $st ($i64) [$r2 + 0] $r3
;
||
    + $r3 ($i64) $r26 -8
;
||
    $ld ($i64) $r4 [$r3 + 0]
    + $r5 ($i64) $r26 -16
;
||
    $ld ($i64) $r6 [$r5 + 0]
;
||
    $v + $r7 ($vi4) $r4 $r6
    + $r8 ($i64) $r26 -24
;
||
    $st ($i64) [$r8 + 0] $r7
    + $r9 ($i64) $r26 -8
;
||
    $ld ($i64) $r10 [$r9 + 0]
    + $r11 ($i64) $r26 -16
;
||
    $ld ($i64) $r12 [$r11 + 0]
;
||
    $v + $r13 ($vu8) $r10 $r12
    + $r14 ($i64) $r26 -32
;
||
    $st ($i64) [$r14 + 0] $r13
    + $r15 ($i64) $r26 -24
;
||
    $ld ($i64) $r16 [$r15 + 0]
    + $r17 ($i64) $r26 -32
;
||
    $ld ($i64) $r18 [$r17 + 0]
;
||
    + $r19 ($i64) $r16 $r18
;
||
    $st ($i64) [$r28 + 0] $r19
;
||
    $ld ($i64) $r20 [$r28 + 0]
;
||
    & $r21 ($i64) $r20 255
;
||
    $cast ($i32) $r22 ($i64) $r21
;
||
    + $r1 ($i64) $r0 $r22
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
