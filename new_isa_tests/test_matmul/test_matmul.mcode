// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 840
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r28 72
    + $r2 ($i64) $r0 1
;
||
    $st ($i32) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r28 72
    + $r3 ($i64) $r0 2
;
||
    $st ($i32) [$r2 + 8] $r3
;
||
    + $r3 ($i64) $r28 72
    + $r4 ($i64) $r0 3
;
||
    $st ($i32) [$r3 + 16] $r4
;
||
    + $r4 ($i64) $r28 72
    + $r5 ($i64) $r0 4
;
||
    $st ($i32) [$r4 + 24] $r5
;
||
    + $r5 ($i64) $r28 72
    + $r6 ($i64) $r0 5
;
||
    $st ($i32) [$r5 + 32] $r6
;
||
    + $r6 ($i64) $r28 72
    + $r7 ($i64) $r0 6
;
||
    $st ($i32) [$r6 + 40] $r7
;
||
    + $r7 ($i64) $r28 72
    + $r8 ($i64) $r0 7
;
||
    $st ($i32) [$r7 + 48] $r8
;
||
    + $r8 ($i64) $r28 72
    + $r9 ($i64) $r0 8
;
||
    $st ($i32) [$r8 + 56] $r9
;
||
    + $r9 ($i64) $r28 72
    + $r10 ($i64) $r0 9
;
||
    $st ($i32) [$r9 + 64] $r10
;
||
    + $r10 ($i64) $r28 144
    + $r11 ($i64) $r0 9
;
||
    $st ($i32) [$r10 + 0] $r11
;
||
    + $r11 ($i64) $r28 144
    + $r12 ($i64) $r0 8
;
||
    $st ($i32) [$r11 + 8] $r12
;
||
    + $r12 ($i64) $r28 144
    + $r13 ($i64) $r0 7
;
||
    $st ($i32) [$r12 + 16] $r13
;
||
    + $r13 ($i64) $r28 144
    + $r14 ($i64) $r0 6
;
||
    $st ($i32) [$r13 + 24] $r14
;
||
    + $r14 ($i64) $r28 144
    + $r15 ($i64) $r0 5
;
||
    $st ($i32) [$r14 + 32] $r15
;
||
    + $r15 ($i64) $r28 144
    + $r16 ($i64) $r0 4
;
||
    $st ($i32) [$r15 + 40] $r16
;
||
    + $r16 ($i64) $r28 144
    + $r17 ($i64) $r0 3
;
||
    $st ($i32) [$r16 + 48] $r17
;
||
    + $r17 ($i64) $r28 144
    + $r18 ($i64) $r0 2
;
||
    $st ($i32) [$r17 + 56] $r18
;
||
    + $r18 ($i64) $r28 144
    + $r19 ($i64) $r0 1
;
||
    $st ($i32) [$r18 + 64] $r19
;
||
    + $r19 ($i64) $r26 -8
    + $r20 ($i64) $r0 0
;
||
    $st ($i32) [$r19 + 0] $r20
;
fc_1:
||
    + $r20 ($i64) $r26 -8
;
||
    $ld ($i32) $r21 [$r20 + 0]
    + $r22 ($i64) $r0 3
;
||
    - $r23 ($i64) $r22 $r21
;
||
    ? ($i64) $r23 > $goto fb_2
;
||
    ? ($i64) $r0 == $goto fe_4
;
fb_2:
||
    + $r22 ($i64) $r26 -16
    + $r23 ($i64) $r0 0
;
||
    $st ($i32) [$r22 + 0] $r23
;
fc_5:
||
    + $r23 ($i64) $r26 -16
;
||
    $ld ($i32) $r24 [$r23 + 0]
    + $r25 ($i64) $r0 3
;
||
    - $r29 ($i64) $r25 $r24
;
||
    ? ($i64) $r29 > $goto fb_6
;
||
    ? ($i64) $r0 == $goto fe_8
;
fb_6:
||
    + $r25 ($i64) $r26 -32
    + $r29 ($i64) $r0 0
;
||
    $st ($i32) [$r25 + 0] $r29
;
||
    + $r29 ($i64) $r26 -24
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r29 + 0] $r30
;
fc_9:
||
    + $r30 ($i64) $r26 -24
;
||
    $ld ($i32) $r31 [$r30 + 0]
    + $r1 ($i64) $r0 3
;
||
    - $r2 ($i64) $r1 $r31
;
||
    ? ($i64) $r2 > $goto fb_10
;
||
    ? ($i64) $r0 == $goto fe_12
;
fb_10:
||
    + $r1 ($i64) $r26 -32
;
||
    $ld ($i32) $r2 [$r1 + 0]
    + $r3 ($i64) $r26 -8
;
||
    $ld ($i32) $r4 [$r3 + 0]
;
||
    * $r5 ($i64) $r4 3
    + $r6 ($i64) $r26 -24
;
||
    $ld ($i32) $r7 [$r6 + 0]
;
||
    + $r8 ($i64) $r5 $r7
;
||
    * $r9 ($i64) $r8 8
    + $r10 ($i64) $r28 72
;
||
    + $r12 ($i64) $r9 72
;
||
    + $r12 ($i64) $r28 $r12
;
||
    $ld ($i32) $r11 [$r12 + 0]
;
||
    + $r12 ($i64) $r26 -24
;
||
    $ld ($i32) $r13 [$r12 + 0]
;
||
    * $r14 ($i64) $r13 3
    + $r15 ($i64) $r26 -16
;
||
    $ld ($i32) $r16 [$r15 + 0]
;
||
    + $r17 ($i64) $r14 $r16
;
||
    * $r18 ($i64) $r17 8
    + $r19 ($i64) $r28 144
;
||
    + $r21 ($i64) $r18 144
;
||
    + $r21 ($i64) $r28 $r21
;
||
    $ld ($i32) $r20 [$r21 + 0]
;
||
    * $r21 ($i64) $r11 $r20
;
||
    + $r22 ($i64) $r2 $r21
    + $r23 ($i64) $r26 -32
;
||
    $st ($i32) [$r23 + 0] $r22
;
fi_11:
||
    + $r24 ($i64) $r26 -24
;
||
    $ld ($i32) $r25 [$r24 + 0]
;
||
    + $r29 ($i64) $r0 $r25
    + $r30 ($i64) $r25 1
    + $r31 ($i64) $r26 -24
;
||
    $st ($i32) [$r31 + 0] $r30
    ? ($i64) $r0 == $goto fc_9
;
fe_12:
||
    + $r1 ($i64) $r26 -32
;
||
    $ld ($i32) $r3 [$r1 + 0]
    + $r4 ($i64) $r26 -8
;
||
    $ld ($i32) $r6 [$r4 + 0]
;
||
    * $r5 ($i64) $r6 3
    + $r7 ($i64) $r26 -16
;
||
    $ld ($i32) $r8 [$r7 + 0]
;
||
    + $r9 ($i64) $r5 $r8
;
||
    * $r12 ($i64) $r9 8
    + $r13 ($i64) $r28 0
;
||
    $st ($i64) [$r13 + $r12] $r3
;
fi_7:
||
    + $r15 ($i64) $r26 -16
;
||
    $ld ($i32) $r14 [$r15 + 0]
;
||
    + $r16 ($i64) $r0 $r14
    + $r17 ($i64) $r14 1
    + $r18 ($i64) $r26 -16
;
||
    $st ($i32) [$r18 + 0] $r17
    ? ($i64) $r0 == $goto fc_5
;
fe_8:
||
    + $r11 ($i64) $r26 -8
;
||
    $ld ($i32) $r20 [$r11 + 0]
;
||
    + $r2 ($i64) $r0 $r20
    + $r21 ($i64) $r20 1
    + $r23 ($i64) $r26 -8
;
||
    $st ($i32) [$r23 + 0] $r21
    ? ($i64) $r0 == $goto fc_1
;
fe_4:
||
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
