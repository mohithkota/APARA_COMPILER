// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 0] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
    + $r26 ($i64) $r0 $r27
    $set $r1 0 840
;
||
    - $r27 ($i64) $r27 $r1
    + $r2 ($i64) $r0 9
    $fsqrt $r1 ($f32) $r2
;
||
    + $r2 ($i64) $r26 -16
;
||
    $st ($i64) [$r2 + 0] $r1
    + $r4 ($i64) $r0 4
    $fsqrt $r3 ($f16) $r4
;
||
    + $r4 ($i64) $r26 -32
;
||
    $st ($i64) [$r4 + 0] $r3
    + $r5 ($i64) $r26 -16
;
||
    $ld ($i64) $r6 [$r5 + 0]
    + $r7 ($i64) $r26 -32
;
||
    $ld ($i64) $r8 [$r7 + 0]
;
||
    + $r9 ($i64) $r6 $r8
    $cast ($i32) $r10 ($i64) $r9
    $st ($i64) [$r28 + 0] $r10
    + $r11 ($i64) $r26 -16
;
||
    $ld ($i64) $r12 [$r11 + 0]
    $cast ($i32) $r13 ($i64) $r12
    + $r1 ($i64) $r0 $r13
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
