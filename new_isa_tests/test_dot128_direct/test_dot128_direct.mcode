// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 816
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    + $r2 ($i64) $r0 0
;
||
    $st ($i32) [$r1 + 0] $r2
;
fc_1:
||
    + $r2 ($i64) $r26 -8
;
||
    $ld ($i32) $r3 [$r2 + 0]
    + $r4 ($i64) $r0 16
;
||
    - $r5 ($i64) $r4 $r3
;
||
    ? ($i64) $r5 > $goto fb_2
;
||
    ? ($i64) $r0 == $goto fe_4
;
fb_2:
||
    + $r4 ($i64) $r26 -8
;
||
    $ld ($i32) $r5 [$r4 + 0]
;
||
    + $r6 ($i64) $r5 1
    + $r7 ($i64) $r26 -8
;
||
    $ld ($i32) $r8 [$r7 + 0]
    + $r9 ($i64) $r28 0
;
||
    $st ($i8) [$r9 + $r8] $r6
    + $r10 ($i64) $r26 -8
;
||
    $ld ($i32) $r11 [$r10 + 0]
    + $r12 ($i64) $r28 16
    + $r13 ($i64) $r0 1
;
||
    $st ($i8) [$r12 + $r11] $r13
;
fi_3:
||
    + $r13 ($i64) $r26 -8
;
||
    $ld ($i32) $r14 [$r13 + 0]
;
||
    + $r15 ($i64) $r0 $r14
    + $r16 ($i64) $r14 1
    + $r17 ($i64) $r26 -8
;
||
    $st ($i32) [$r17 + 0] $r16
    ? ($i64) $r0 == $goto fc_1
;
fe_4:
||
    + $r18 ($i64) $r28 0
    + $r19 ($i64) $r28 16
;
||
    $ld ($u128) $r2 [$r18 + 0]
;
||
    + $r20 ($i64) $r0 $r2
    + $r21 ($i64) $r0 $r3
    $ld ($u128) $r2 [$r19 + 0]
;
||
    + $r22 ($i64) $r0 $r2
    + $r23 ($i64) $r0 $r3
;
||
    $dot $r2 ($vu8) $r20 $r22
;
||
    $dot $accumulate $r2 ($vu8) $r21 $r23
    + $r3 ($i64) $r28 32
;
||
    $st ($i64) [$r3 + 0] $r2
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
