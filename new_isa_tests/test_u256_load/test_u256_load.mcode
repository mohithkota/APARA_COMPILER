    + $r22 ($i64) $r0 -4
;
||
    + $r1 ($i64) $r0 $r22
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_8:
||
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
