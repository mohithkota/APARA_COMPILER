    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    $st ($i64) [$r4 + 24] $r5
;
||
    + $r5 ($i64) $r28 32
    + $r6 ($i64) $r28 0
;
||
    $ld ($u256) $r8 [$r6 + 0]
;
||
    + $r7 ($i64) $r0 $r8
    + $r12 ($i64) $r0 $r9
    + $r13 ($i64) $r0 $r10
    + $r14 ($i64) $r0 $r11
;
