// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 856
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    + $r2 ($i64) $r0 0
;
||
    $st ($i32) [$r1 + 0] $r2
;
fc_1:
||
    + $r2 ($i64) $r26 -8
;
||
    $ld ($i32) $r3 [$r2 + 0]
    + $r4 ($i64) $r0 16
;
||
    - $r5 ($i64) $r4 $r3
;
||
    ? ($i64) $r5 > $goto fb_2
;
||
    ? ($i64) $r0 == $goto fe_4
;
fb_2:
||
    + $r4 ($i64) $r26 -8
;
||
    $ld ($i32) $r5 [$r4 + 0]
;
||
    + $r6 ($i64) $r5 1
    + $r7 ($i64) $r26 -8
;
||
    $ld ($i32) $r8 [$r7 + 0]
;
||
    * $r9 ($i64) $r8 8
    + $r10 ($i64) $r28 0
;
||
    $st ($i8) [$r10 + $r9] $r6
    + $r11 ($i64) $r26 -8
;
||
    $ld ($i32) $r12 [$r11 + 0]
;
||
    * $r13 ($i64) $r12 8
    + $r14 ($i64) $r28 128
    + $r15 ($i64) $r0 1
;
||
    $st ($i8) [$r14 + $r13] $r15
;
fi_3:
||
    + $r15 ($i64) $r26 -8
;
||
    $ld ($i32) $r16 [$r15 + 0]
;
||
    + $r17 ($i64) $r0 $r16
    + $r18 ($i64) $r16 1
    + $r19 ($i64) $r26 -8
;
||
    $st ($i32) [$r19 + 0] $r18
    ? ($i64) $r0 == $goto fc_1
;
fe_4:
||
    + $r20 ($i64) $r28 256
    + $r21 ($i64) $r28 0
;
||
    $ld ($u128) $r2 [$r21 + 0]
;
||
    + $r22 ($i64) $r0 $r2
    + $r23 ($i64) $r0 $r3
;
||
    $st ($i64) [$r20 + 0] $r22
    $st ($i64) [$r20 + 8] $r23
    + $r2 ($i64) $r28 256
    $ld ($i64) $r3 [$r28 + 256]
    + $r24 ($i64) $r26 -16
;
||
    $st ($i64) [$r24 + 0] $r3
    + $r25 ($i64) $r28 256
    + $r30 ($i64) $r0 8
;
||
    + $r31 ($i64) $r30 256
;
||
    + $r31 ($i64) $r28 $r31
;
||
    $ld ($i64) $r29 [$r31 + 0]
    + $r30 ($i64) $r26 -24
;
||
    $st ($i64) [$r30 + 0] $r29
    + $r31 ($i64) $r28 256
    + $r1 ($i64) $r28 128
;
||
    $ld ($u128) $r4 [$r1 + 0]
;
||
    + $r7 ($i64) $r0 $r4
    + $r8 ($i64) $r0 $r5
;
||
    $st ($i64) [$r31 + 0] $r7
    $st ($i64) [$r31 + 8] $r8
    + $r4 ($i64) $r28 256
    $ld ($i64) $r5 [$r28 + 256]
    + $r10 ($i64) $r26 -32
;
||
    $st ($i64) [$r10 + 0] $r5
    + $r9 ($i64) $r28 256
    + $r11 ($i64) $r0 8
;
||
    + $r12 ($i64) $r11 256
;
||
    + $r12 ($i64) $r28 $r12
;
||
    $ld ($i64) $r6 [$r12 + 0]
    + $r11 ($i64) $r26 -40
;
||
    $st ($i64) [$r11 + 0] $r6
    + $r12 ($i64) $r26 -16
;
||
    $ld ($i64) $r14 [$r12 + 0]
    + $r13 ($i64) $r26 -24
;
||
    $ld ($i64) $r15 [$r13 + 0]
    + $r16 ($i64) $r26 -32
;
||
    $ld ($i64) $r19 [$r16 + 0]
    + $r18 ($i64) $r26 -40
;
||
    $ld ($i64) $r21 [$r18 + 0]
    $dot $r22 ($vu8) $r14 $r19
;
||
    $dot $accumulate $r22 ($vu8) $r15 $r21
    + $r20 ($i64) $r26 -48
;
||
    $st ($i64) [$r20 + 0] $r22
    + $r23 ($i64) $r26 -48
;
||
    $ld ($i64) $r24 [$r23 + 0]
    + $r3 ($i64) $r0 136
;
||
    - $r30 ($i64) $r24 $r3
;
||
    ? ($i64) $r30 != $goto if_t_5
;
||
    ? ($i64) $r0 == $goto if_e_6
;
if_t_5:
||
    + $r3 ($i64) $r0 -1
;
||
    + $r1 ($i64) $r0 $r3
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_6:
||
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
