// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 0] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 8] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 16] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
    + $r26 ($i64) $r0 $r27
    $set $r1 0 856
;
||
    - $r27 ($i64) $r27 $r1
    $set $r1 0 0
    + $r3 ($i64) $r0 10
;
||
    | $r2 ($i64) $r3 $r1
    + $r3 ($i64) $r26 -16
;
||
    $st ($i64) [$r3 + 0] $r2
    + $r4 ($i64) $r26 -16
    $vreduce $r5 ($vi32) $r4
    $cast ($i32) $r6 ($i64) $r5
    $st ($i64) [$r28 + 0] $r6
    $set $r7 0 0
;
||
    $set $r7 2 2
    + $r9 ($i64) $r0 1
;
||
    | $r8 ($i64) $r9 $r7
    $set $r9 0 0
;
||
    | $r10 ($i64) $r8 $r9
    $set $r11 0 0
;
||
    | $r12 ($i64) $r10 $r11
    + $r13 ($i64) $r26 -32
;
||
    $st ($i64) [$r13 + 0] $r12
    + $r14 ($i64) $r26 -32
    $vreduce $r15 ($vi16) $r14
    $cast ($i32) $r16 ($i64) $r15
    $st ($i64) [$r28 + 8] $r16
    $set $r17 0 512
    + $r19 ($i64) $r0 1
;
||
    | $r18 ($i64) $r19 $r17
    $set $r19 0 0
;
||
    $set $r19 2 3
;
||
    | $r20 ($i64) $r18 $r19
    $set $r21 0 0
;
||
    $set $r21 2 1024
;
||
    | $r22 ($i64) $r20 $r21
    $set $r23 0 0
;
||
    | $r24 ($i64) $r22 $r23
    $set $r25 0 0
;
||
    | $r29 ($i64) $r24 $r25
    $set $r30 0 0
;
||
    | $r31 ($i64) $r29 $r30
    $set $r1 0 0
;
||
    | $r3 ($i64) $r31 $r1
    + $r2 ($i64) $r26 -48
;
||
    $st ($i64) [$r2 + 0] $r3
    + $r4 ($i64) $r26 -48
    $vreduce $r5 ($vi8) $r4
    $cast ($i32) $r6 ($i64) $r5
    $st ($i64) [$r28 + 16] $r6
    $ld ($i64) $r7 [$r28 + 0]
    $ld ($i64) $r8 [$r28 + 8]
;
||
    + $r9 ($i64) $r7 $r8
    $ld ($i64) $r10 [$r28 + 16]
;
||
    + $r11 ($i64) $r9 $r10
;
||
    + $r1 ($i64) $r0 $r11
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
