// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 0] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 8] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 16] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 832
;
||
    - $r27 ($i64) $r27 $r1
    $set $r1 0 0
    $set $r2 0 0
    + $r3 ($i64) $r0 20
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
;
||
    << $r2 ($i64) $r2 16
;
||
    | $r1 ($i64) $r1 $r2
    + $r3 ($i64) $r0 10
;
||
    | $r2 ($i64) $r3 $r1
    + $r3 ($i64) $r26 -8
;
||
    $st ($i64) [$r3 + 0] $r2
    + $r4 ($i64) $r26 -8
;
||
    $ld ($i64) $r5 [$r4 + 0]
;
||
    $vreduce $r6 ($vi32) $r5
;
||
    $cast ($i32) $r7 ($i64) $r6
;
||
    $st ($i32) [$r28 + 0] $r7
    $set $r8 0 0
    + $r9 ($i64) $r0 2
;
||
    << $r9 ($i64) $r9 16
;
||
    | $r8 ($i64) $r8 $r9
    + $r10 ($i64) $r0 1
;
||
    | $r9 ($i64) $r10 $r8
    $set $r10 0 0
    $set $r11 0 0
    + $r12 ($i64) $r0 3
;
||
    << $r12 ($i64) $r12 16
;
||
    | $r11 ($i64) $r11 $r12
;
||
    << $r11 ($i64) $r11 16
;
||
    | $r10 ($i64) $r10 $r11
;
||
    | $r11 ($i64) $r9 $r10
    $set $r12 0 0
    $set $r13 0 0
    $set $r14 0 0
    + $r15 ($i64) $r0 4
;
||
    << $r15 ($i64) $r15 16
;
||
    | $r14 ($i64) $r14 $r15
;
||
    << $r14 ($i64) $r14 16
;
||
    | $r13 ($i64) $r13 $r14
;
||
    << $r13 ($i64) $r13 16
;
||
    | $r12 ($i64) $r12 $r13
;
||
    | $r13 ($i64) $r11 $r12
    + $r14 ($i64) $r26 -16
;
||
    $st ($i64) [$r14 + 0] $r13
    + $r15 ($i64) $r26 -16
;
||
    $ld ($i64) $r16 [$r15 + 0]
;
||
    $vreduce $r17 ($vi16) $r16
;
||
    $cast ($i32) $r18 ($i64) $r17
;
||
    $st ($i32) [$r28 + 8] $r18
    $set $r19 0 512
    + $r21 ($i64) $r0 1
;
||
    | $r20 ($i64) $r21 $r19
    $set $r21 0 0
    + $r22 ($i64) $r0 3
;
||
    << $r22 ($i64) $r22 16
;
||
    | $r21 ($i64) $r21 $r22
;
||
    | $r22 ($i64) $r20 $r21
    $set $r23 0 0
    $set $r24 0 1024
;
||
    << $r24 ($i64) $r24 16
;
||
    | $r23 ($i64) $r23 $r24
;
||
    | $r24 ($i64) $r22 $r23
    $set $r25 0 0
    $set $r29 0 0
    + $r30 ($i64) $r0 5
;
||
    << $r30 ($i64) $r30 16
;
||
    | $r29 ($i64) $r29 $r30
;
||
    << $r29 ($i64) $r29 16
;
||
    | $r25 ($i64) $r25 $r29
;
||
    | $r29 ($i64) $r24 $r25
    $set $r30 0 0
    $set $r31 0 0
    $set $r1 0 1536
;
||
    << $r1 ($i64) $r1 16
;
||
    | $r31 ($i64) $r31 $r1
;
||
    << $r31 ($i64) $r31 16
;
||
    | $r30 ($i64) $r30 $r31
;
||
    | $r31 ($i64) $r29 $r30
    $set $r1 0 0
    $set $r3 0 0
    $set $r2 0 0
    + $r4 ($i64) $r0 7
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r2 ($i64) $r2 $r4
;
||
    << $r2 ($i64) $r2 16
;
||
    | $r3 ($i64) $r3 $r2
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r1 ($i64) $r1 $r3
;
||
    | $r3 ($i64) $r31 $r1
    $set $r2 0 0
    $set $r4 0 0
    $set $r5 0 0
    $set $r6 0 2048
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r2 ($i64) $r2 $r4
;
||
    | $r4 ($i64) $r3 $r2
    + $r5 ($i64) $r26 -24
;
||
    $st ($i64) [$r5 + 0] $r4
    + $r6 ($i64) $r26 -24
;
||
    $ld ($i64) $r7 [$r6 + 0]
;
||
    $vreduce $r8 ($vi8) $r7
;
||
    $cast ($i32) $r9 ($i64) $r8
;
||
    $st ($i32) [$r28 + 16] $r9
    $ld ($i32) $r10 [$r28 + 0]
    $ld ($i32) $r11 [$r28 + 8]
;
||
    + $r12 ($i64) $r10 $r11
    $ld ($i32) $r14 [$r28 + 16]
;
||
    + $r13 ($i64) $r12 $r14
;
||
    + $r1 ($i64) $r0 $r13
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
