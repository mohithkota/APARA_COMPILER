// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 840
;
||
    - $r27 ($i64) $r27 $r1
    $set $r1 0 0
    + $r2 ($i64) $r0 2
;
||
    << $r2 ($i64) $r2 16
;
||
    | $r1 ($i64) $r1 $r2
    + $r3 ($i64) $r0 1
;
||
    | $r2 ($i64) $r3 $r1
    $set $r3 0 0
    $set $r4 0 0
    + $r5 ($i64) $r0 3
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    | $r4 ($i64) $r2 $r3
    $set $r5 0 0
    $set $r6 0 0
    $set $r7 0 0
    + $r8 ($i64) $r0 4
;
||
    << $r8 ($i64) $r8 16
;
||
    | $r7 ($i64) $r7 $r8
;
||
    << $r7 ($i64) $r7 16
;
||
    | $r6 ($i64) $r6 $r7
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    | $r6 ($i64) $r4 $r5
    + $r7 ($i64) $r26 -8
;
||
    $st ($i64) [$r7 + 0] $r6
    $set $r8 0 0
    + $r9 ($i64) $r0 2
;
||
    << $r9 ($i64) $r9 16
;
||
    | $r8 ($i64) $r8 $r9
    + $r10 ($i64) $r0 1
;
||
    | $r9 ($i64) $r10 $r8
    $set $r10 0 0
    $set $r11 0 0
    + $r12 ($i64) $r0 3
;
||
    << $r12 ($i64) $r12 16
;
||
    | $r11 ($i64) $r11 $r12
;
||
    << $r11 ($i64) $r11 16
;
||
    | $r10 ($i64) $r10 $r11
;
||
    | $r11 ($i64) $r9 $r10
    $set $r12 0 0
    $set $r13 0 0
    $set $r14 0 0
    + $r15 ($i64) $r0 4
;
||
    << $r15 ($i64) $r15 16
;
||
    | $r14 ($i64) $r14 $r15
;
||
    << $r14 ($i64) $r14 16
;
||
    | $r13 ($i64) $r13 $r14
;
||
    << $r13 ($i64) $r13 16
;
||
    | $r12 ($i64) $r12 $r13
;
||
    | $r13 ($i64) $r11 $r12
    + $r14 ($i64) $r26 -16
;
||
    $st ($i64) [$r14 + 0] $r13
    + $r15 ($i64) $r26 -8
;
||
    $ld ($i64) $r16 [$r15 + 0]
    + $r17 ($i64) $r26 -16
;
||
    $ld ($i64) $r18 [$r17 + 0]
;
||
    $dot $r19 ($vi16) $r16 $r18
    + $r20 ($i64) $r26 -24
;
||
    $st ($i64) [$r20 + 0] $r19
    + $r21 ($i64) $r26 -24
;
||
    $ld ($i64) $r22 [$r21 + 0]
    + $r23 ($i64) $r28 0
;
||
    $st ($i64) [$r23 + 0] $r22
    + $r24 ($i64) $r26 -24
;
||
    $ld ($i64) $r25 [$r24 + 0]
    + $r29 ($i64) $r26 -8
;
||
    $ld ($i64) $r30 [$r29 + 0]
    + $r31 ($i64) $r26 -16
;
||
    $ld ($i64) $r1 [$r31 + 0]
    + $r2 ($i64) $r0 $r25
;
||
    $dot $accumulate $r2 ($vi16) $r30 $r1
    + $r3 ($i64) $r26 -32
;
||
    $st ($i64) [$r3 + 0] $r2
    + $r4 ($i64) $r26 -32
;
||
    $ld ($i64) $r5 [$r4 + 0]
    + $r7 ($i64) $r28 0
;
||
    $st ($i64) [$r7 + 8] $r5
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
