// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 0] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 8] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
    + $r26 ($i64) $r0 $r27
    $set $r1 0 872
;
||
    - $r27 ($i64) $r27 $r1
    $set $r1 0 0
;
||
    $set $r1 2 2
    + $r3 ($i64) $r0 1
;
||
    | $r2 ($i64) $r3 $r1
    $set $r3 0 0
;
||
    | $r4 ($i64) $r2 $r3
    $set $r5 0 0
;
||
    | $r6 ($i64) $r4 $r5
    + $r7 ($i64) $r26 -16
;
||
    $st ($i64) [$r7 + 0] $r6
    $set $r8 0 0
;
||
    $set $r8 2 2
    + $r10 ($i64) $r0 1
;
||
    | $r9 ($i64) $r10 $r8
    $set $r10 0 0
;
||
    | $r11 ($i64) $r9 $r10
    $set $r12 0 0
;
||
    | $r13 ($i64) $r11 $r12
    + $r14 ($i64) $r26 -32
;
||
    $st ($i64) [$r14 + 0] $r13
    + $r15 ($i64) $r26 -16
    + $r16 ($i64) $r26 -32
    $dot $r17 ($vi16) $r15 $r16
    + $r18 ($i64) $r26 -48
;
||
    $st ($i64) [$r18 + 0] $r17
    + $r19 ($i64) $r26 -48
;
||
    $ld ($i64) $r20 [$r19 + 0]
    $cast ($i32) $r21 ($i64) $r20
    $st ($i64) [$r28 + 0] $r21
    + $r22 ($i64) $r26 -48
    + $r23 ($i64) $r26 -16
    + $r24 ($i64) $r26 -32
;
||
    + $r25 ($i64) $r0 $r22
    $dot $accumulate $r25 ($vi16) $r23 $r24
    + $r29 ($i64) $r26 -64
;
||
    $st ($i64) [$r29 + 0] $r25
    + $r30 ($i64) $r26 -64
;
||
    $ld ($i64) $r31 [$r30 + 0]
    $cast ($i32) $r1 ($i64) $r31
    $st ($i64) [$r28 + 8] $r1
    $ld ($i64) $r2 [$r28 + 0]
    $ld ($i64) $r3 [$r28 + 8]
;
||
    + $r4 ($i64) $r2 $r3
;
||
    + $r1 ($i64) $r0 $r4
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
