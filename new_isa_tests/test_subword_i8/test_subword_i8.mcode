// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 1
;
||
    $st ($i8) [$r28 + 0] $r30
    + $r30 ($i64) $r0 2
;
||
    $st ($i8) [$r28 + 8] $r30
    + $r30 ($i64) $r0 3
;
||
    $st ($i8) [$r28 + 16] $r30
    + $r30 ($i64) $r0 4
;
||
    $st ($i8) [$r28 + 24] $r30
    + $r30 ($i64) $r0 5
;
||
    $st ($i8) [$r28 + 32] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
    + $r26 ($i64) $r0 $r27
    $set $r1 0 840
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    + $r2 ($i64) $r0 7
;
||
    $st ($i8) [$r1 + 0] $r2
    + $r2 ($i64) $r26 -8
;
||
    $ld ($i8) $r3 [$r2 + 0]
;
||
    + $r4 ($i64) $r3 1
    + $r5 ($i64) $r26 -8
;
||
    $st ($i8) [$r5 + 0] $r4
    + $r6 ($i64) $r26 -8
;
||
    $ld ($i8) $r7 [$r6 + 0]
    + $r8 ($i64) $r0 8
;
||
    - $r9 ($i64) $r7 $r8
;
||
    ? ($i64) $r9 != $goto if_t_1
;
||
    ? ($i64) $r0 == $goto if_e_2
;
if_t_1:
||
    + $r8 ($i64) $r0 -1
;
||
    + $r1 ($i64) $r0 $r8
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_2:
||
    + $r9 ($i64) $r28 0
    + $r10 ($i64) $r0 9
;
||
    $st ($i8) [$r9 + 0] $r10
    + $r10 ($i64) $r28 0
    $ld ($i8) $r11 [$r28 + 0]
    + $r12 ($i64) $r0 9
;
||
    - $r13 ($i64) $r11 $r12
;
||
    ? ($i64) $r13 != $goto if_t_3
;
||
    ? ($i64) $r0 == $goto if_e_4
;
if_t_3:
||
    + $r12 ($i64) $r0 -2
;
||
    + $r1 ($i64) $r0 $r12
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_4:
||
    + $r13 ($i64) $r28 0
    + $r15 ($i64) $r0 24
;
||
    + $r16 ($i64) $r15 0
;
||
    + $r16 ($i64) $r28 $r16
;
||
    $ld ($i8) $r14 [$r16 + 0]
    + $r15 ($i64) $r0 4
;
||
    - $r16 ($i64) $r14 $r15
;
||
    ? ($i64) $r16 != $goto if_t_5
;
||
    ? ($i64) $r0 == $goto if_e_6
;
if_t_5:
||
    + $r15 ($i64) $r0 -3
;
||
    + $r1 ($i64) $r0 $r15
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_6:
||
    $ld ($i8) $r16 [$r28 + 32]
;
||
    + $r17 ($i64) $r16 1
;
||
    $st ($i8) [$r28 + 32] $r17
    $ld ($i8) $r18 [$r28 + 32]
    + $r19 ($i64) $r0 6
;
||
    - $r20 ($i64) $r18 $r19
;
||
    ? ($i64) $r20 != $goto if_t_7
;
||
    ? ($i64) $r0 == $goto if_e_8
;
if_t_7:
||
    + $r19 ($i64) $r0 -4
;
||
    + $r1 ($i64) $r0 $r19
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_8:
||
    + $r20 ($i64) $r28 0
    + $r22 ($i64) $r0 8
;
||
    + $r23 ($i64) $r22 0
;
||
    + $r23 ($i64) $r28 $r23
;
||
    $ld ($i8) $r21 [$r23 + 0]
    + $r22 ($i64) $r26 -16
;
||
    $st ($i8) [$r22 + 0] $r21
    + $r23 ($i64) $r28 0
    + $r25 ($i64) $r0 16
;
||
    + $r29 ($i64) $r25 0
;
||
    + $r29 ($i64) $r28 $r29
;
||
    $ld ($i8) $r24 [$r29 + 0]
    + $r25 ($i64) $r26 -24
;
||
    $st ($i8) [$r25 + 0] $r24
    + $r29 ($i64) $r26 -16
;
||
    $ld ($i8) $r30 [$r29 + 0]
    + $r31 ($i64) $r26 -24
;
||
    $ld ($i8) $r1 [$r31 + 0]
;
||
    + $r2 ($i64) $r30 $r1
    + $r3 ($i64) $r26 -32
;
||
    $st ($i8) [$r3 + 0] $r2
    + $r5 ($i64) $r26 -32
;
||
    $ld ($i8) $r4 [$r5 + 0]
    + $r6 ($i64) $r0 5
;
||
    - $r7 ($i64) $r4 $r6
;
||
    ? ($i64) $r7 != $goto if_t_9
;
||
    ? ($i64) $r0 == $goto if_e_10
;
if_t_9:
||
    + $r6 ($i64) $r0 -5
;
||
    + $r1 ($i64) $r0 $r6
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_10:
||
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
