||
    $st ($i8) [$r28 + 192] $r30
;
||
    $set $r30 0 1000
;
||
    $st ($i16) [$r28 + 200] $r30
;
||
    $set $r30 0 34464
    $set $r31 0 1
;
||
    << $r31 ($i64) $r31 16
;
||
