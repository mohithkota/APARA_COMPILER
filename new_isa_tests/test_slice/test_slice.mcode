// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 0] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 8] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 816
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    $set $r2 0 43981
;
||
    $st ($i32) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -8
;
||
    $ld ($i32) $r3 [$r2 + 0]
;
||
    $slice $r4 7 4 $r3
;
||
    $st ($i32) [$r28 + 0] $r4
    + $r5 ($i64) $r26 -8
;
||
    $ld ($i32) $r6 [$r5 + 0]
;
||
    $slice $r7 15 8 $r6
;
||
    $st ($i32) [$r28 + 8] $r7
    $ld ($i32) $r8 [$r28 + 0]
;
||
    $ld ($i32) $r9 [$r28 + 8]
;
||
    + $r10 ($i64) $r8 $r9
;
||
    + $r1 ($i64) $r0 $r10
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
