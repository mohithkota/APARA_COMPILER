// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 0] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 8] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 16] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 840
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    $set $r2 0 52719
    $set $r3 0 30891
    $set $r4 0 13398
    + $r5 ($i64) $r0 18
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
;
||
    $st ($i64) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -8
;
||
    $ld ($i64) $r3 [$r2 + 0]
;
||
    $cast ($i8) $r4 ($i64) $r3
    + $r5 ($i64) $r26 -16
;
||
    $st ($i8) [$r5 + 0] $r4
    + $r6 ($i64) $r26 -8
;
||
    $ld ($i64) $r7 [$r6 + 0]
;
||
    $cast ($i16) $r8 ($i64) $r7
    + $r9 ($i64) $r26 -24
;
||
    $st ($i16) [$r9 + 0] $r8
    + $r10 ($i64) $r26 -8
;
||
    $ld ($i64) $r11 [$r10 + 0]
;
||
    $cast ($i32) $r12 ($i64) $r11
    + $r13 ($i64) $r26 -32
;
||
    $st ($i32) [$r13 + 0] $r12
    + $r14 ($i64) $r26 -16
;
||
    $ld ($i8) $r15 [$r14 + 0]
;
||
    $st ($i32) [$r28 + 0] $r15
    + $r16 ($i64) $r26 -24
;
||
    $ld ($i16) $r17 [$r16 + 0]
;
||
    $st ($i32) [$r28 + 8] $r17
    + $r18 ($i64) $r26 -32
;
||
    $ld ($i32) $r19 [$r18 + 0]
;
||
    $st ($i32) [$r28 + 16] $r19
    + $r20 ($i64) $r26 -16
;
||
    $ld ($i8) $r21 [$r20 + 0]
    + $r22 ($i64) $r26 -24
;
||
    $ld ($i16) $r23 [$r22 + 0]
;
||
    + $r24 ($i64) $r21 $r23
    + $r25 ($i64) $r26 -32
;
||
    $ld ($i32) $r29 [$r25 + 0]
;
||
    + $r30 ($i64) $r24 $r29
;
||
    $cast ($i32) $r31 ($i64) $r30
;
||
    + $r1 ($i64) $r0 $r31
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
