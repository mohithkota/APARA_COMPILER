// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 848
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    $set $r2 0 4
    $set $r3 0 3
    $set $r4 0 2
    + $r5 ($i64) $r0 1
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
;
||
    $st ($i64) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -16
    $set $r3 0 8
    $set $r4 0 7
    $set $r5 0 6
    + $r6 ($i64) $r0 5
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    $st ($i64) [$r2 + 0] $r3
;
||
    + $r3 ($i64) $r26 -24
    $set $r4 0 4
    $set $r5 0 0
    + $r6 ($i64) $r0 3
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    $st ($i64) [$r3 + 0] $r4
;
||
    + $r4 ($i64) $r26 -32
    $set $r5 0 6
    $set $r6 0 0
    + $r7 ($i64) $r0 5
;
||
    << $r7 ($i64) $r7 16
;
||
    | $r6 ($i64) $r6 $r7
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    $st ($i64) [$r4 + 0] $r5
;
||
    + $r5 ($i64) $r26 -8
;
||
    $ld ($i64) $r6 [$r5 + 0]
    + $r7 ($i64) $r26 -16
;
||
    $ld ($i64) $r8 [$r7 + 0]
;
||
    $v + $r9 ($vu16) $r6 $r8
    + $r10 ($i64) $r26 -40
;
||
    $st ($i64) [$r10 + 0] $r9
    + $r11 ($i64) $r26 -40
;
||
    $ld ($i64) $r12 [$r11 + 0]
    $set $r13 0 12
    $set $r14 0 10
    $set $r15 0 8
    + $r16 ($i64) $r0 6
;
||
    << $r16 ($i64) $r16 16
;
||
    | $r15 ($i64) $r15 $r16
;
||
    << $r15 ($i64) $r15 16
;
||
    | $r14 ($i64) $r14 $r15
;
||
    << $r14 ($i64) $r14 16
;
||
    | $r13 ($i64) $r13 $r14
;
||
    - $r14 ($i64) $r12 $r13
;
||
    ? ($i64) $r14 != $goto if_t_1
;
||
    ? ($i64) $r0 == $goto if_e_2
;
if_t_1:
||
    + $r13 ($i64) $r0 -1
;
||
    + $r1 ($i64) $r0 $r13
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_2:
||
    + $r14 ($i64) $r26 -24
;
||
    $ld ($i64) $r15 [$r14 + 0]
    + $r16 ($i64) $r26 -32
;
||
    $ld ($i64) $r17 [$r16 + 0]
;
||
    $v + $r18 ($vu32) $r15 $r17
    + $r19 ($i64) $r26 -40
;
||
    $st ($i64) [$r19 + 0] $r18
    + $r20 ($i64) $r26 -40
;
||
    $ld ($i64) $r21 [$r20 + 0]
    $set $r22 0 10
    $set $r23 0 0
    + $r24 ($i64) $r0 8
;
||
    << $r24 ($i64) $r24 16
;
||
    | $r23 ($i64) $r23 $r24
;
||
    << $r23 ($i64) $r23 16
;
||
    | $r22 ($i64) $r22 $r23
;
||
    - $r23 ($i64) $r21 $r22
;
||
    ? ($i64) $r23 != $goto if_t_3
;
||
    ? ($i64) $r0 == $goto if_e_4
;
if_t_3:
||
    + $r22 ($i64) $r0 -2
;
||
    + $r1 ($i64) $r0 $r22
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_4:
||
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
