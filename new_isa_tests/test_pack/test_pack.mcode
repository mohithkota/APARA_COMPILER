// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 0] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
    + $r26 ($i64) $r0 $r27
    $set $r1 0 856
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -16
    $set $r2 0 48879
;
||
    $st ($i64) [$r1 + 0] $r2
    + $r2 ($i64) $r26 -32
    $set $r3 0 57005
;
||
    $st ($i64) [$r2 + 0] $r3
    + $r3 ($i64) $r26 -16
    + $r4 ($i64) $r26 -32
;
||
    + $r1 ($i64) $r0 $r3
    + $r2 ($i64) $r0 $r4
    $pack $r5 32 16 $r1
;
||
    + $r1 ($i64) $r26 -48
;
||
    $st ($i64) [$r1 + 0] $r5
    + $r2 ($i64) $r26 -48
;
||
    $ld ($i64) $r6 [$r2 + 0]
    $cast ($i32) $r7 ($i64) $r6
    $st ($i64) [$r28 + 0] $r7
    + $r8 ($i64) $r26 -48
;
||
    $ld ($i64) $r9 [$r8 + 0]
    $set $r11 0 65535
;
||
    & $r10 ($i64) $r9 $r11
    $cast ($i32) $r11 ($i64) $r10
    + $r1 ($i64) $r0 $r11
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
