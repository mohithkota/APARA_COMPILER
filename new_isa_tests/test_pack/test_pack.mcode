// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 0] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 832
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    $set $r2 0 48879
;
||
    $st ($i64) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -16
    $set $r3 0 57005
;
||
    $st ($i64) [$r2 + 0] $r3
;
||
    + $r3 ($i64) $r26 -8
;
||
    $ld ($i64) $r4 [$r3 + 0]
    + $r5 ($i64) $r26 -16
;
||
    $ld ($i64) $r6 [$r5 + 0]
    + $r2 ($i64) $r0 $r4
;
||
    + $r3 ($i64) $r0 $r6
;
||
    $pack 32 $r7 16 $r2
    + $r2 ($i64) $r26 -24
;
||
    $st ($i64) [$r2 + 0] $r7
    + $r3 ($i64) $r26 -24
;
||
    $ld ($i64) $r8 [$r3 + 0]
;
||
    $cast ($i32) $r9 ($i64) $r8
;
||
    $st ($i32) [$r28 + 0] $r9
    + $r10 ($i64) $r26 -24
;
||
    $ld ($i64) $r11 [$r10 + 0]
    $set $r13 0 65535
;
||
    & $r12 ($i64) $r11 $r13
;
||
    $cast ($i32) $r13 ($i64) $r12
;
||
    + $r1 ($i64) $r0 $r13
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
