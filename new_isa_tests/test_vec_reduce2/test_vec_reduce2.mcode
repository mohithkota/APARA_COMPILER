// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 840
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    $set $r2 0 1800
    $set $r3 0 1286
    $set $r4 0 772
    + $r5 ($i64) $r0 258
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
;
||
    $st ($i64) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -16
    $set $r3 0 4
    $set $r4 0 3
    $set $r5 0 2
    + $r6 ($i64) $r0 1
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    $st ($i64) [$r2 + 0] $r3
;
||
    + $r3 ($i64) $r26 -24
    $set $r4 0 4
    $set $r5 0 0
    + $r6 ($i64) $r0 3
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    $st ($i64) [$r3 + 0] $r4
;
||
    + $r4 ($i64) $r26 -8
;
||
    $ld ($i64) $r5 [$r4 + 0]
;
||
    $vreduce $r6 ($vi8) $r5
    + $r7 ($i64) $r26 -32
;
||
    $st ($i64) [$r7 + 0] $r6
    + $r8 ($i64) $r26 -32
;
||
    $ld ($i64) $r9 [$r8 + 0]
    + $r10 ($i64) $r0 36
;
||
    - $r11 ($i64) $r9 $r10
;
||
    ? ($i64) $r11 != $goto if_t_1
;
||
    ? ($i64) $r0 == $goto if_e_2
;
if_t_1:
||
    + $r10 ($i64) $r0 -1
;
||
    + $r1 ($i64) $r0 $r10
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_2:
||
    + $r11 ($i64) $r26 -16
;
||
    $ld ($i64) $r12 [$r11 + 0]
;
||
    $vreduce $r13 ($vi16) $r12
    + $r14 ($i64) $r26 -32
;
||
    $st ($i64) [$r14 + 0] $r13
    + $r15 ($i64) $r26 -32
;
||
    $ld ($i64) $r16 [$r15 + 0]
    + $r17 ($i64) $r0 10
;
||
    - $r18 ($i64) $r16 $r17
;
||
    ? ($i64) $r18 != $goto if_t_3
;
||
    ? ($i64) $r0 == $goto if_e_4
;
if_t_3:
||
    + $r17 ($i64) $r0 -2
;
||
    + $r1 ($i64) $r0 $r17
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_4:
||
    + $r18 ($i64) $r26 -24
;
||
    $ld ($i64) $r19 [$r18 + 0]
;
||
    $vreduce $r20 ($vi32) $r19
    + $r21 ($i64) $r26 -32
;
||
    $st ($i64) [$r21 + 0] $r20
    + $r22 ($i64) $r26 -32
;
||
    $ld ($i64) $r23 [$r22 + 0]
    + $r24 ($i64) $r0 7
;
||
    - $r25 ($i64) $r23 $r24
;
||
    ? ($i64) $r25 != $goto if_t_5
;
||
    ? ($i64) $r0 == $goto if_e_6
;
if_t_5:
||
    + $r24 ($i64) $r0 -3
;
||
    + $r1 ($i64) $r0 $r24
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_6:
||
    + $r25 ($i64) $r26 -8
;
||
    $ld ($i64) $r29 [$r25 + 0]
;
||
    $vreduce $r30 ($vu8) $r29
    + $r31 ($i64) $r26 -32
;
||
    $st ($i64) [$r31 + 0] $r30
    + $r1 ($i64) $r26 -32
;
||
    $ld ($i64) $r2 [$r1 + 0]
    + $r3 ($i64) $r0 36
;
||
    - $r4 ($i64) $r2 $r3
;
||
    ? ($i64) $r4 != $goto if_t_7
;
||
    ? ($i64) $r0 == $goto if_e_8
;
if_t_7:
||
    + $r3 ($i64) $r0 -4
;
||
    + $r1 ($i64) $r0 $r3
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_8:
||
    + $r4 ($i64) $r26 -16
;
||
    $ld ($i64) $r5 [$r4 + 0]
;
||
    $vreduce $r7 ($vu16) $r5
    + $r6 ($i64) $r26 -32
;
||
    $st ($i64) [$r6 + 0] $r7
    + $r8 ($i64) $r26 -32
;
||
    $ld ($i64) $r9 [$r8 + 0]
    + $r10 ($i64) $r0 10
;
||
    - $r11 ($i64) $r9 $r10
;
||
    ? ($i64) $r11 != $goto if_t_9
;
||
    ? ($i64) $r0 == $goto if_e_10
;
if_t_9:
||
    + $r10 ($i64) $r0 -5
;
||
    + $r1 ($i64) $r0 $r10
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_10:
||
    + $r11 ($i64) $r26 -24
;
||
    $ld ($i64) $r12 [$r11 + 0]
;
||
    $vreduce $r14 ($vu32) $r12
    + $r13 ($i64) $r26 -32
;
||
    $st ($i64) [$r13 + 0] $r14
    + $r15 ($i64) $r26 -32
;
||
    $ld ($i64) $r16 [$r15 + 0]
    + $r17 ($i64) $r0 7
;
||
    - $r18 ($i64) $r16 $r17
;
||
    ? ($i64) $r18 != $goto if_t_11
;
||
    ? ($i64) $r0 == $goto if_e_12
;
if_t_11:
||
    + $r17 ($i64) $r0 -6
;
||
    + $r1 ($i64) $r0 $r17
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_12:
||
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
