// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 0] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 8] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 16] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 24] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
    + $r26 ($i64) $r0 $r27
    $set $r1 0 856
;
||
    - $r27 ($i64) $r27 $r1
    $set $r1 0 0
    + $r3 ($i64) $r0 1
;
||
    | $r2 ($i64) $r3 $r1
    + $r3 ($i64) $r26 -8
;
||
    $st ($i64) [$r3 + 0] $r2
    $set $r4 0 0
    + $r6 ($i64) $r0 3
;
||
    | $r5 ($i64) $r6 $r4
    + $r6 ($i64) $r26 -16
;
||
    $st ($i64) [$r6 + 0] $r5
    + $r7 ($i64) $r26 -8
;
||
    $ld ($i64) $r8 [$r7 + 0]
    + $r9 ($i64) $r26 -16
;
||
    $ld ($i64) $r10 [$r9 + 0]
    $v + $r11 ($vi32) $r8 $r10
    $cast ($i32) $r12 ($i64) $r11
    $st ($i32) [$r28 + 0] $r12
    $set $r13 0 0
;
||
    $set $r13 2 20
    + $r15 ($i64) $r0 10
;
||
    | $r14 ($i64) $r15 $r13
    $set $r15 0 0
;
||
    | $r16 ($i64) $r14 $r15
    $set $r17 0 0
;
||
    | $r18 ($i64) $r16 $r17
    + $r19 ($i64) $r26 -24
;
||
    $st ($i64) [$r19 + 0] $r18
    $set $r20 0 0
;
||
    $set $r20 2 2
    + $r22 ($i64) $r0 1
;
||
    | $r21 ($i64) $r22 $r20
    $set $r22 0 0
;
||
    | $r23 ($i64) $r21 $r22
    $set $r24 0 0
;
||
    | $r25 ($i64) $r23 $r24
    + $r29 ($i64) $r26 -32
;
||
    $st ($i64) [$r29 + 0] $r25
    + $r30 ($i64) $r26 -24
;
||
    $ld ($i64) $r31 [$r30 + 0]
    + $r1 ($i64) $r26 -32
;
||
    $ld ($i64) $r3 [$r1 + 0]
    $v - $r2 ($vi16) $r31 $r3
    $cast ($i32) $r4 ($i64) $r2
    $st ($i32) [$r28 + 8] $r4
    $set $r6 0 768
    + $r7 ($i64) $r0 2
;
||
    | $r5 ($i64) $r7 $r6
    $set $r7 0 0
;
||
    $set $r7 2 4
;
||
    | $r9 ($i64) $r5 $r7
    $set $r8 0 0
;
||
    $set $r8 2 1280
;
||
    | $r10 ($i64) $r9 $r8
    + $r11 ($i64) $r26 -40
;
||
    $st ($i64) [$r11 + 0] $r10
    $set $r12 0 512
    + $r14 ($i64) $r0 2
;
||
    | $r13 ($i64) $r14 $r12
    $set $r14 0 0
;
||
    $set $r14 2 2
;
||
    | $r15 ($i64) $r13 $r14
    $set $r16 0 0
;
||
    $set $r16 2 512
;
||
    | $r17 ($i64) $r15 $r16
    + $r19 ($i64) $r26 -48
;
||
    $st ($i64) [$r19 + 0] $r17
    + $r18 ($i64) $r26 -40
;
||
    $ld ($i64) $r20 [$r18 + 0]
    + $r21 ($i64) $r26 -48
;
||
    $ld ($i64) $r22 [$r21 + 0]
    $v * $r23 ($vi8) $r20 $r22
    $cast ($i32) $r24 ($i64) $r23
    $st ($i32) [$r28 + 16] $r24
    + $r29 ($i64) $r26 -8
;
||
    $ld ($i64) $r25 [$r29 + 0]
    + $r1 ($i64) $r0 10
    $v + $r30 ($vi32) $r25 $r1 $replicate
    $cast ($i32) $r1 ($i64) $r30
;
||
    $st ($i32) [$r28 + 24] $r1
    $ld ($i32) $r31 [$r28 + 0]
;
||
    + $r1 ($i64) $r0 $r31
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
