// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 0] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 8] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 16] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 24] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
    + $r26 ($i64) $r0 $r27
    $set $r1 0 904
;
||
    - $r27 ($i64) $r27 $r1
    $set $r1 0 0
    + $r3 ($i64) $r0 1
;
||
    | $r2 ($i64) $r3 $r1
    + $r3 ($i64) $r26 -16
;
||
    $st ($i64) [$r3 + 0] $r2
    $set $r4 0 0
    + $r6 ($i64) $r0 3
;
||
    | $r5 ($i64) $r6 $r4
    + $r6 ($i64) $r26 -32
;
||
    $st ($i64) [$r6 + 0] $r5
    + $r7 ($i64) $r26 -16
    + $r8 ($i64) $r26 -32
    $v + $r9 ($vi32) $r7 $r8
    $cast ($i32) $r10 ($i64) $r9
    $st ($i64) [$r28 + 0] $r10
    $set $r11 0 0
;
||
    $set $r11 2 20
    + $r13 ($i64) $r0 10
;
||
    | $r12 ($i64) $r13 $r11
    $set $r13 0 0
;
||
    | $r14 ($i64) $r12 $r13
    $set $r15 0 0
;
||
    | $r16 ($i64) $r14 $r15
    + $r17 ($i64) $r26 -48
;
||
    $st ($i64) [$r17 + 0] $r16
    $set $r18 0 0
;
||
    $set $r18 2 2
    + $r20 ($i64) $r0 1
;
||
    | $r19 ($i64) $r20 $r18
    $set $r20 0 0
;
||
    | $r21 ($i64) $r19 $r20
    $set $r22 0 0
;
||
    | $r23 ($i64) $r21 $r22
    + $r24 ($i64) $r26 -64
;
||
    $st ($i64) [$r24 + 0] $r23
    + $r25 ($i64) $r26 -48
    + $r29 ($i64) $r26 -64
    $v - $r30 ($vi16) $r25 $r29
    $cast ($i32) $r31 ($i64) $r30
    $st ($i64) [$r28 + 8] $r31
    $set $r1 0 768
    + $r2 ($i64) $r0 2
;
||
    | $r3 ($i64) $r2 $r1
    $set $r2 0 0
;
||
    $set $r2 2 4
;
||
    | $r4 ($i64) $r3 $r2
    $set $r6 0 0
;
||
    $set $r6 2 1280
;
||
    | $r5 ($i64) $r4 $r6
    + $r7 ($i64) $r26 -80
;
||
    $st ($i64) [$r7 + 0] $r5
    $set $r8 0 512
    + $r10 ($i64) $r0 2
;
||
    | $r9 ($i64) $r10 $r8
    $set $r10 0 0
;
||
    $set $r10 2 2
;
||
    | $r11 ($i64) $r9 $r10
    $set $r12 0 0
;
||
    $set $r12 2 512
;
||
    | $r13 ($i64) $r11 $r12
    + $r14 ($i64) $r26 -96
;
||
    $st ($i64) [$r14 + 0] $r13
    + $r15 ($i64) $r26 -80
    + $r17 ($i64) $r26 -96
    $v * $r16 ($vi8) $r15 $r17
    $cast ($i32) $r18 ($i64) $r16
    $st ($i64) [$r28 + 16] $r18
    + $r19 ($i64) $r26 -16
    + $r21 ($i64) $r0 10
;
||
    $v + $r20 ($vi32) $r19 $r21 $replicate
    $cast ($i32) $r21 ($i64) $r20
    $st ($i64) [$r28 + 24] $r21
    $ld ($i64) $r22 [$r28 + 0]
;
||
    + $r1 ($i64) $r0 $r22
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
