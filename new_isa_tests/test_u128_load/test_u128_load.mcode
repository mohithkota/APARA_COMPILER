// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 808
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r28 0
    $set $r2 0 4369
    $set $r3 0 4369
    $set $r4 0 4369
    $set $r5 0 4369
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
;
||
    $st ($i64) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r28 0
    $set $r3 0 8738
    $set $r4 0 8738
    $set $r5 0 8738
    $set $r6 0 8738
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    $st ($i64) [$r2 + 8] $r3
;
||
    + $r3 ($i64) $r28 16
    + $r4 ($i64) $r28 0
;
||
    $ld ($u128) $r1 [$r4 + 0]
;
||
    $st ($i64) [$r3 + 0] $r1
    $st ($i64) [$r3 + 8] $r2
    + $r5 ($i64) $r28 16
    $ld ($i64) $r6 [$r28 + 16]
    $set $r7 0 4369
    $set $r8 0 4369
    $set $r9 0 4369
    $set $r10 0 4369
;
||
    << $r10 ($i64) $r10 16
;
||
    | $r9 ($i64) $r9 $r10
;
||
    << $r9 ($i64) $r9 16
;
||
    | $r8 ($i64) $r8 $r9
;
||
    << $r8 ($i64) $r8 16
;
||
    | $r7 ($i64) $r7 $r8
;
||
    - $r8 ($i64) $r6 $r7
;
||
    ? ($i64) $r8 != $goto if_t_1
;
||
    ? ($i64) $r0 == $goto if_e_2
;
if_t_1:
||
    + $r7 ($i64) $r0 -1
;
||
    + $r1 ($i64) $r0 $r7
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_2:
||
    + $r8 ($i64) $r28 16
    + $r10 ($i64) $r0 8
;
||
    + $r11 ($i64) $r10 16
;
||
    + $r11 ($i64) $r28 $r11
;
||
    $ld ($i64) $r9 [$r11 + 0]
    $set $r10 0 8738
;
||
    $set $r11 0 8738
    $set $r12 0 8738
    $set $r13 0 8738
;
||
    << $r13 ($i64) $r13 16
;
||
    | $r12 ($i64) $r12 $r13
;
||
    << $r12 ($i64) $r12 16
;
||
    | $r11 ($i64) $r11 $r12
;
||
    << $r11 ($i64) $r11 16
;
||
    | $r10 ($i64) $r10 $r11
;
||
    - $r11 ($i64) $r9 $r10
;
||
    ? ($i64) $r11 != $goto if_t_3
;
||
    ? ($i64) $r0 == $goto if_e_4
;
if_t_3:
||
    + $r10 ($i64) $r0 -2
;
||
    + $r1 ($i64) $r0 $r10
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_4:
||
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
