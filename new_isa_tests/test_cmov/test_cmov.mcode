// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 0] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 8] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i32) [$r28 + 16] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
    + $r26 ($i64) $r0 $r27
    $set $r1 0 832
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    + $r2 ($i64) $r0 5
;
||
    $st ($i32) [$r1 + 0] $r2
    + $r2 ($i64) $r0 -3
    + $r3 ($i64) $r26 -16
;
||
    $st ($i32) [$r3 + 0] $r2
    + $r4 ($i64) $r26 -24
    + $r5 ($i64) $r0 0
;
||
    $st ($i32) [$r4 + 0] $r5
    + $r5 ($i64) $r26 -8
;
||
    $ld ($i32) $r6 [$r5 + 0]
    $set $r8 0 999
    + $r9 ($i64) $r0 100
;
||
    + $r7 ($i64) $r0 $r8
    $cmov ($i64) $r6 > $r7 $r9
;
||
    $st ($i32) [$r28 + 0] $r7
    + $r8 ($i64) $r26 -16
;
||
    $ld ($i32) $r9 [$r8 + 0]
    $set $r11 0 999
    + $r12 ($i64) $r0 200
;
||
    + $r10 ($i64) $r0 $r11
    $cmov ($i64) $r9 < $r10 $r12
;
||
    $st ($i32) [$r28 + 8] $r10
    + $r11 ($i64) $r26 -24
;
||
    $ld ($i32) $r12 [$r11 + 0]
    $set $r14 0 999
    + $r15 ($i64) $r0 300
;
||
    + $r13 ($i64) $r0 $r14
    $cmov ($i64) $r12 == $r13 $r15
;
||
    $st ($i32) [$r28 + 16] $r13
    $ld ($i32) $r14 [$r28 + 0]
    $ld ($i32) $r15 [$r28 + 8]
;
||
    + $r16 ($i64) $r14 $r15
    $ld ($i32) $r17 [$r28 + 16]
;
||
    + $r18 ($i64) $r16 $r17
;
||
    + $r1 ($i64) $r0 $r18
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
