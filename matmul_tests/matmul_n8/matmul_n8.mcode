// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 824
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    + $r2 ($i64) $r0 0
;
||
    $st ($i32) [$r1 + 0] $r2
;
wc_1:
||
    + $r2 ($i64) $r26 -8
;
||
    $ld ($i32) $r3 [$r2 + 0]
    + $r4 ($i64) $r0 8
;
||
    - $r5 ($i64) $r4 $r3
;
||
    ? ($i64) $r5 > $goto wb_2
;
||
    ? ($i64) $r0 == $goto we_3
;
wb_2:
||
    + $r4 ($i64) $r26 -16
    + $r5 ($i64) $r0 0
;
||
    $st ($i32) [$r4 + 0] $r5
;
wc_4:
||
