wb_8:
||
    + $r17 ($i64) $r26 -8
;
||
    $ld ($i32) $r19 [$r17 + 0]
;
||
    * $r21 ($i64) $r19 16
    + $r20 ($i64) $r26 -16
;
||
    $ld ($i32) $r14 [$r20 + 0]
;
||
    + $r22 ($i64) $r21 $r14
    + $r23 ($i64) $r28 0
    + $r25 ($i64) $r0 0
;
||
    $st ($i8) [$r23 + $r22] $r25
;
||
    + $r25 ($i64) $r26 -8
;
||
    $ld ($i32) $r24 [$r25 + 0]
;
||
    * $r29 ($i64) $r24 16
    + $r30 ($i64) $r26 -16
;
||
    $ld ($i32) $r31 [$r30 + 0]
;
||
    + $r2 ($i64) $r29 $r31
    + $r3 ($i64) $r28 128
    + $r5 ($i64) $r0 0
;
||
    $st ($i8) [$r3 + $r2] $r5
;
||
    + $r5 ($i64) $r26 -16
;
||
    $ld ($i32) $r4 [$r5 + 0]
;
||
    + $r6 ($i64) $r0 $r4
    + $r8 ($i64) $r4 1
    + $r7 ($i64) $r26 -16
;
||
    $st ($i32) [$r7 + 0] $r8
    ? ($i64) $r0 == $goto wc_7
