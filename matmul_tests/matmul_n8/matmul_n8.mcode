;
||
    ? ($i64) $r0 == $goto we_6
;
wb_5:
||
    + $r7 ($i64) $r26 -8
;
||
    $ld ($i32) $r8 [$r7 + 0]
;
||
    * $r9 ($i64) $r8 8
    + $r10 ($i64) $r26 -16
;
||
    $ld ($i32) $r11 [$r10 + 0]
;
||
    + $r12 ($i64) $r9 $r11
;
||
    + $r13 ($i64) $r12 1
    + $r15 ($i64) $r0 256
;
||
    / $r16 ($i64) $r13 $r15
;
||
    * $r16 ($i64) $r16 $r15
;
||
    - $r14 ($i64) $r13 $r16
    + $r15 ($i64) $r26 -8
;
||
    $ld ($i32) $r16 [$r15 + 0]
;
||
    * $r17 ($i64) $r16 16
    + $r18 ($i64) $r26 -16
;
||
    $ld ($i32) $r19 [$r18 + 0]
;
||
    + $r20 ($i64) $r17 $r19
    + $r21 ($i64) $r28 0
;
||
    $st ($i8) [$r21 + $r20] $r14
    + $r22 ($i64) $r26 -16
;
||
    $ld ($i32) $r23 [$r22 + 0]
;
||
    * $r24 ($i64) $r23 8
    + $r25 ($i64) $r26 -8
;
||
    $ld ($i32) $r29 [$r25 + 0]
;
||
    + $r30 ($i64) $r24 $r29
;
||
    + $r31 ($i64) $r30 1
    + $r2 ($i64) $r0 256
;
||
    / $r3 ($i64) $r31 $r2
;
||
    * $r3 ($i64) $r3 $r2
;
||
    - $r1 ($i64) $r31 $r3
    + $r2 ($i64) $r26 -8
;
||
    $ld ($i32) $r3 [$r2 + 0]
;
||
    * $r4 ($i64) $r3 16
    + $r5 ($i64) $r26 -16
;
||
    $ld ($i32) $r6 [$r5 + 0]
;
||
    + $r7 ($i64) $r4 $r6
    + $r8 ($i64) $r28 128
;
||
    $st ($i8) [$r8 + $r7] $r1
    + $r10 ($i64) $r26 -16
;
||
    $ld ($i32) $r9 [$r10 + 0]
;
||
    + $r11 ($i64) $r0 $r9
    + $r12 ($i64) $r9 1
    + $r13 ($i64) $r26 -16
;
||
    $st ($i32) [$r13 + 0] $r12
    ? ($i64) $r0 == $goto wc_4
;
we_6:
||
    + $r15 ($i64) $r26 -16
    + $r16 ($i64) $r0 8
;
||
    $st ($i32) [$r15 + 0] $r16
;
wc_7:
||
    + $r16 ($i64) $r26 -16
;
||
    $ld ($i32) $r18 [$r16 + 0]
    + $r17 ($i64) $r0 16
;
||
    - $r19 ($i64) $r17 $r18
;
||
    ? ($i64) $r19 > $goto wb_8
;
||
    ? ($i64) $r0 == $goto we_9
