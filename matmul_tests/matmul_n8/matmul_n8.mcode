wb_11:
||
    + $r17 ($i64) $r26 -16
    + $r19 ($i64) $r0 0
;
||
    $st ($i32) [$r17 + 0] $r19
;
wc_13:
||
    + $r19 ($i64) $r26 -16
;
||
    $ld ($i32) $r20 [$r19 + 0]
    + $r21 ($i64) $r0 8
;
||
    - $r14 ($i64) $r21 $r20
;
||
    ? ($i64) $r14 > $goto wb_14
;
||
    ? ($i64) $r0 == $goto we_15
;
wb_14:
||
    + $r21 ($i64) $r26 -8
;
||
    $ld ($i32) $r14 [$r21 + 0]
;
||
    * $r23 ($i64) $r14 16
    + $r22 ($i64) $r28 0
;
||
    + $r25 ($i64) $r22 $r23
    + $r24 ($i64) $r26 -16
;
||
    $ld ($i32) $r30 [$r24 + 0]
;
||
    * $r29 ($i64) $r30 16
    + $r31 ($i64) $r28 128
;
||
    + $r3 ($i64) $r31 $r29
    $ld ($u128) $r4 [$r25 + 0]
;
||
    + $r2 ($i64) $r0 $r4
    + $r7 ($i64) $r0 $r5
    $ld ($u128) $r4 [$r3 + 0]
;
||
    + $r8 ($i64) $r0 $r4
    + $r1 ($i64) $r0 $r5
;
||
    $dot $r4 ($vu8) $r2 $r8
;
||
    $dot $accumulate $r4 ($vu8) $r7 $r1
    + $r5 ($i64) $r26 -8
;
||
    $ld ($i32) $r10 [$r5 + 0]
;
||
    * $r12 ($i64) $r10 8
    + $r13 ($i64) $r26 -16
;
||
    $ld ($i32) $r15 [$r13 + 0]
;
||
    + $r16 ($i64) $r12 $r15
;
||
    * $r18 ($i64) $r16 8
    + $r17 ($i64) $r28 256
;
||
    $st ($i64) [$r17 + $r18] $r4
    + $r19 ($i64) $r26 -16
