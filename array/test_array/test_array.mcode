// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 10
;
||
    $st ($i64) [$r28 + 0] $r30
    + $r30 ($i64) $r0 20
;
||
    $st ($i64) [$r28 + 8] $r30
    + $r30 ($i64) $r0 30
;
||
    $st ($i64) [$r28 + 16] $r30
    + $r30 ($i64) $r0 40
;
||
    $st ($i64) [$r28 + 24] $r30
    + $r30 ($i64) $r0 50
;
||
    $st ($i64) [$r28 + 32] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 40] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
    + $r26 ($i64) $r0 $r27
    $set $r1 0 816
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    + $r2 ($i64) $r0 0
;
||
    $st ($i64) [$r1 + 0] $r2
;
fc_1:
||
    + $r2 ($i64) $r26 -8
;
||
    $ld ($i64) $r3 [$r2 + 0]
    + $r4 ($i64) $r0 5
;
||
    - $r5 ($i64) $r4 $r3
;
||
    ? ($i64) $r5 > $goto fb_2
;
||
    ? ($i64) $r0 == $goto fe_4
;
fb_2:
||
    $ld ($i64) $r4 [$r28 + 40]
    + $r5 ($i64) $r26 -8
;
||
    $ld ($i64) $r6 [$r5 + 0]
;
||
    * $r7 ($i64) $r6 8
    + $r8 ($i64) $r28 0
;
||
    + $r10 ($i64) $r7 0
;
||
    + $r10 ($i64) $r28 $r10
;
||
    $ld ($i64) $r9 [$r10 + 0]
;
||
    + $r10 ($i64) $r4 $r9
;
||
    $st ($i64) [$r28 + 40] $r10
;
fi_3:
||
    + $r11 ($i64) $r26 -8
;
||
    $ld ($i64) $r12 [$r11 + 0]
;
||
    + $r13 ($i64) $r0 $r12
    + $r14 ($i64) $r12 1
    + $r15 ($i64) $r26 -8
;
||
    $st ($i64) [$r15 + 0] $r14
    ? ($i64) $r0 == $goto fc_1
;
fe_4:
||
    $ld ($i64) $r16 [$r28 + 40]
;
||
    + $r1 ($i64) $r0 $r16
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
