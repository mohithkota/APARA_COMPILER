// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 10
;
||
    $st ($i32) [$r28 + 0] $r30
;
||
    + $r30 ($i64) $r0 20
;
||
    $st ($i32) [$r28 + 8] $r30
;
||
    + $r30 ($i64) $r0 30
;
||
    $st ($i32) [$r28 + 16] $r30
;
||
    + $r30 ($i64) $r0 40
;
||
    $st ($i32) [$r28 + 24] $r30
;
||
    + $r30 ($i64) $r0 50
;
||
    $st ($i32) [$r28 + 32] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 824
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -16
    + $r2 ($i64) $r0 0
;
||
    $st ($i32) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -8
    + $r3 ($i64) $r0 0
;
||
    $st ($i32) [$r2 + 0] $r3
;
fc_1:
||
    + $r3 ($i64) $r26 -8
;
||
    $ld ($i32) $r4 [$r3 + 0]
    + $r5 ($i64) $r0 5
;
||
    - $r6 ($i64) $r5 $r4
;
||
    ? ($i64) $r6 > $goto fb_2
;
||
    ? ($i64) $r0 == $goto fe_4
;
fb_2:
||
    + $r5 ($i64) $r26 -8
;
||
    $ld ($i32) $r6 [$r5 + 0]
;
||
    * $r7 ($i64) $r6 8
    + $r8 ($i64) $r28 0
;
||
    + $r10 ($i64) $r7 0
;
||
    + $r10 ($i64) $r28 $r10
;
||
    $ld ($i32) $r9 [$r10 + 0]
;
||
    + $r10 ($i64) $r26 -8
;
||
    $ld ($i32) $r11 [$r10 + 0]
;
||
    * $r12 ($i64) $r11 8
    + $r13 ($i64) $r28 40
;
||
    $st ($i64) [$r13 + $r12] $r9
    + $r14 ($i64) $r26 -16
;
||
    $ld ($i32) $r15 [$r14 + 0]
    + $r16 ($i64) $r26 -8
;
||
    $ld ($i32) $r17 [$r16 + 0]
;
||
    * $r18 ($i64) $r17 8
    + $r19 ($i64) $r28 0
;
||
    + $r21 ($i64) $r18 0
;
||
    + $r21 ($i64) $r28 $r21
;
||
    $ld ($i32) $r20 [$r21 + 0]
;
||
    + $r21 ($i64) $r15 $r20
    + $r22 ($i64) $r26 -16
;
||
    $st ($i32) [$r22 + 0] $r21
;
fi_3:
||
    + $r23 ($i64) $r26 -8
;
||
    $ld ($i32) $r24 [$r23 + 0]
;
||
    + $r25 ($i64) $r0 $r24
    + $r29 ($i64) $r24 1
    + $r30 ($i64) $r26 -8
;
||
    $st ($i32) [$r30 + 0] $r29
    ? ($i64) $r0 == $goto fc_1
;
fe_4:
||
    + $r31 ($i64) $r26 -16
;
||
    $ld ($i32) $r1 [$r31 + 0]
    + $r2 ($i64) $r28 40
;
||
    $st ($i64) [$r2 + 40] $r1
;
||
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
