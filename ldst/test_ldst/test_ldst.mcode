// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $set $r30 0 1000
;
||
    $st ($i64) [$r28 + 0] $r30
    $set $r30 0 2000
;
||
    $st ($i64) [$r28 + 8] $r30
    $set $r30 0 3000
;
||
    $st ($i64) [$r28 + 16] $r30
    $set $r30 0 4000
;
||
    $st ($i64) [$r28 + 24] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 32] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 40] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 48] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 56] $r30
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 64] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
    + $r26 ($i64) $r0 $r27
    $set $r1 0 808
;
||
    - $r27 ($i64) $r27 $r1
    $ld ($i64) $r1 [$r28 + 0]
;
||
    $st ($i64) [$r28 + 32] $r1
    $ld ($i64) $r2 [$r28 + 0]
    $ld ($i64) $r3 [$r28 + 8]
;
||
    + $r4 ($i64) $r2 $r3
;
||
    $st ($i64) [$r28 + 40] $r4
    $ld ($i64) $r5 [$r28 + 24]
    $ld ($i64) $r6 [$r28 + 16]
;
||
    - $r7 ($i64) $r5 $r6
;
||
    $st ($i64) [$r28 + 48] $r7
    $ld ($i64) $r8 [$r28 + 0]
    $ld ($i64) $r9 [$r28 + 8]
;
||
    * $r10 ($i64) $r8 $r9
;
||
    $st ($i64) [$r28 + 56] $r10
    $ld ($i64) $r11 [$r28 + 0]
;
||
    $st ($i64) [$r28 + 64] $r11
    $ld ($i64) $r12 [$r28 + 8]
;
||
    $st ($i64) [$r28 + 64] $r12
    $ld ($i64) $r13 [$r28 + 32]
;
||
    + $r1 ($i64) $r0 $r13
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
