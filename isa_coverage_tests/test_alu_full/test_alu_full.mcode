// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 840
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    + $r2 ($i64) $r0 17
;
||
    $st ($i64) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -16
    + $r3 ($i64) $r0 5
;
||
    $st ($i64) [$r2 + 0] $r3
;
||
    + $r3 ($i64) $r26 -8
;
||
    $ld ($i64) $r4 [$r3 + 0]
    + $r5 ($i64) $r26 -16
;
||
    $ld ($i64) $r6 [$r5 + 0]
;
||
    + $r7 ($i64) $r4 $r6
    + $r8 ($i64) $r28 0
;
||
    $st ($i64) [$r8 + 0] $r7
    + $r9 ($i64) $r26 -8
;
||
    $ld ($i64) $r10 [$r9 + 0]
    + $r11 ($i64) $r26 -16
;
||
    $ld ($i64) $r12 [$r11 + 0]
;
||
    - $r13 ($i64) $r10 $r12
    + $r14 ($i64) $r28 0
;
||
    $st ($i64) [$r14 + 8] $r13
    + $r15 ($i64) $r26 -8
;
||
    $ld ($i64) $r16 [$r15 + 0]
    + $r17 ($i64) $r26 -16
;
||
    $ld ($i64) $r18 [$r17 + 0]
;
||
    * $r19 ($i64) $r16 $r18
    + $r20 ($i64) $r28 0
;
||
    $st ($i64) [$r20 + 16] $r19
    + $r21 ($i64) $r26 -8
;
||
    $ld ($i64) $r22 [$r21 + 0]
    + $r23 ($i64) $r26 -16
;
||
    $ld ($i64) $r24 [$r23 + 0]
;
||
    / $r25 ($i64) $r22 $r24
    + $r29 ($i64) $r28 0
;
||
    $st ($i64) [$r29 + 24] $r25
    + $r30 ($i64) $r26 -8
;
||
    $ld ($i64) $r31 [$r30 + 0]
    + $r1 ($i64) $r26 -16
;
||
    $ld ($i64) $r2 [$r1 + 0]
;
||
    / $r5 ($i64) $r31 $r2
;
||
    * $r5 ($i64) $r5 $r2
;
||
    - $r3 ($i64) $r31 $r5
    + $r5 ($i64) $r28 0
;
||
    $st ($i64) [$r5 + 32] $r3
    + $r4 ($i64) $r26 -24
    + $r6 ($i64) $r0 12
;
||
    $st ($i64) [$r4 + 0] $r6
;
||
    + $r6 ($i64) $r26 -32
    + $r8 ($i64) $r0 10
;
||
    $st ($i64) [$r6 + 0] $r8
;
||
    + $r8 ($i64) $r26 -24
;
||
    $ld ($i64) $r7 [$r8 + 0]
    + $r9 ($i64) $r26 -32
;
||
    $ld ($i64) $r11 [$r9 + 0]
;
||
    & $r10 ($i64) $r7 $r11
    + $r12 ($i64) $r28 0
;
||
    $st ($i64) [$r12 + 40] $r10
    + $r14 ($i64) $r26 -24
;
||
    $ld ($i64) $r13 [$r14 + 0]
    + $r15 ($i64) $r26 -32
;
||
    $ld ($i64) $r17 [$r15 + 0]
;
||
    | $r16 ($i64) $r13 $r17
    + $r18 ($i64) $r28 0
;
||
    $st ($i64) [$r18 + 48] $r16
    + $r20 ($i64) $r26 -24
;
||
    $ld ($i64) $r19 [$r20 + 0]
    + $r21 ($i64) $r26 -32
;
||
    $ld ($i64) $r23 [$r21 + 0]
;
||
    ^ $r22 ($i64) $r19 $r23
    + $r24 ($i64) $r28 0
;
||
    $st ($i64) [$r24 + 56] $r22
    + $r29 ($i64) $r26 -24
;
||
    $ld ($i64) $r25 [$r29 + 0]
;
||
    << $r30 ($i64) $r25 2
    + $r1 ($i64) $r28 0
;
||
    $st ($i64) [$r1 + 64] $r30
    + $r31 ($i64) $r26 -24
;
||
    $ld ($i64) $r2 [$r31 + 0]
;
||
    >> $r5 ($i64) $r2 1
    + $r3 ($i64) $r28 0
;
||
    $st ($i64) [$r3 + 72] $r5
    + $r4 ($i64) $r26 -24
;
||
    $ld ($i64) $r6 [$r4 + 0]
    + $r8 ($i64) $r26 -32
;
||
    $ld ($i64) $r9 [$r8 + 0]
;
||
    ~& $r7 ($i64) $r6 $r9
    + $r11 ($i64) $r28 0
;
||
    $st ($i64) [$r11 + 80] $r7
    + $r12 ($i64) $r26 -24
;
||
    $ld ($i64) $r10 [$r12 + 0]
    + $r14 ($i64) $r26 -32
;
||
    $ld ($i64) $r15 [$r14 + 0]
;
||
    ~| $r13 ($i64) $r10 $r15
    + $r17 ($i64) $r28 0
;
||
    $st ($i64) [$r17 + 88] $r13
    + $r18 ($i64) $r26 -24
;
||
    $ld ($i64) $r16 [$r18 + 0]
    + $r20 ($i64) $r26 -32
;
||
    $ld ($i64) $r21 [$r20 + 0]
;
||
    ~^ $r19 ($i64) $r16 $r21
    + $r23 ($i64) $r28 0
;
||
    $st ($i64) [$r23 + 96] $r19
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
