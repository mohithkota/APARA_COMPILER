// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 856
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    $set $r2 0 513
    $set $r3 0 1027
    $set $r4 0 1541
    $set $r5 0 2055
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
;
||
    $st ($i64) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -16
    $set $r3 0 1
    $set $r4 0 2
    $set $r5 0 3
    + $r6 ($i64) $r0 4
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    $st ($i64) [$r2 + 0] $r3
;
||
    + $r3 ($i64) $r26 -24
    $set $r4 0 1
    $set $r5 0 0
    + $r6 ($i64) $r0 2
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    $st ($i64) [$r3 + 0] $r4
;
||
    + $r4 ($i64) $r26 -8
;
||
    $ld ($i64) $r5 [$r4 + 0]
;
||
    $vreduce + $r6 ($vi8) $r5
    + $r7 ($i64) $r28 0
;
||
    $st ($i64) [$r7 + 0] $r6
    + $r8 ($i64) $r26 -8
;
||
    $ld ($i64) $r9 [$r8 + 0]
;
||
    $vreduce + $r10 ($vu8) $r9
    + $r11 ($i64) $r28 0
;
||
    $st ($i64) [$r11 + 8] $r10
    + $r12 ($i64) $r26 -16
;
||
    $ld ($i64) $r13 [$r12 + 0]
;
||
    $vreduce + $r14 ($vi16) $r13
    + $r15 ($i64) $r28 0
;
||
    $st ($i64) [$r15 + 16] $r14
    + $r16 ($i64) $r26 -16
;
||
    $ld ($i64) $r17 [$r16 + 0]
;
||
    $vreduce + $r18 ($vu16) $r17
    + $r19 ($i64) $r28 0
;
||
    $st ($i64) [$r19 + 24] $r18
    + $r20 ($i64) $r26 -24
;
||
    $ld ($i64) $r21 [$r20 + 0]
;
||
    $vreduce + $r22 ($vi32) $r21
    + $r23 ($i64) $r28 0
;
||
    $st ($i64) [$r23 + 32] $r22
    + $r24 ($i64) $r26 -24
;
||
    $ld ($i64) $r25 [$r24 + 0]
;
||
    $vreduce + $r29 ($vu32) $r25
    + $r30 ($i64) $r28 0
;
||
    $st ($i64) [$r30 + 40] $r29
    + $r31 ($i64) $r26 -32
    $set $r1 0 513
    $set $r2 0 64515
    $set $r3 0 1541
    $set $r4 0 2055
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
;
||
    << $r2 ($i64) $r2 16
;
||
    | $r1 ($i64) $r1 $r2
;
||
    $st ($i64) [$r31 + 0] $r1
;
||
    + $r1 ($i64) $r26 -40
    $set $r2 0 1
    $set $r3 0 2
    $set $r4 0 3
    $set $r5 0 65532
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
;
||
    $st ($i64) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -48
    $set $r3 0 1
    $set $r4 0 0
    $set $r5 0 65534
    $set $r7 0 65535
;
||
    << $r7 ($i64) $r7 16
;
||
    | $r5 ($i64) $r5 $r7
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
;
||
    << $r4 ($i64) $r4 16
;
||
    | $r3 ($i64) $r3 $r4
;
||
    $st ($i64) [$r2 + 0] $r3
;
||
    + $r3 ($i64) $r26 -32
;
||
    $ld ($i64) $r4 [$r3 + 0]
;
||
    $vreduce + $r5 ($vi8) $r4
    + $r7 ($i64) $r28 0
;
||
    $st ($i64) [$r7 + 48] $r5
    + $r6 ($i64) $r26 -32
;
||
    $ld ($i64) $r8 [$r6 + 0]
;
||
    $vreduce + $r9 ($vu8) $r8
    + $r11 ($i64) $r28 0
;
||
    $st ($i64) [$r11 + 56] $r9
    + $r10 ($i64) $r26 -40
;
||
    $ld ($i64) $r12 [$r10 + 0]
;
||
    $vreduce + $r13 ($vi16) $r12
    + $r15 ($i64) $r28 0
;
||
    $st ($i64) [$r15 + 64] $r13
    + $r14 ($i64) $r26 -40
;
||
    $ld ($i64) $r16 [$r14 + 0]
;
||
    $vreduce + $r17 ($vu16) $r16
    + $r19 ($i64) $r28 0
;
||
    $st ($i64) [$r19 + 72] $r17
    + $r18 ($i64) $r26 -48
;
||
    $ld ($i64) $r20 [$r18 + 0]
;
||
    $vreduce + $r21 ($vi32) $r20
    + $r23 ($i64) $r28 0
;
||
    $st ($i64) [$r23 + 80] $r21
    + $r22 ($i64) $r26 -48
;
||
    $ld ($i64) $r24 [$r22 + 0]
;
||
    $vreduce + $r25 ($vu32) $r24
    + $r30 ($i64) $r28 0
;
||
    $st ($i64) [$r30 + 88] $r25
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
