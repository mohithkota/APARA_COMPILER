// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 808
;
||
    - $r27 ($i64) $r27 $r1
    + $r2 ($i64) $r0 5
    $set $r3 0 999
    + $r4 ($i64) $r0 100
;
||
    + $r1 ($i64) $r0 $r3
;
||
    $cmov ? ($i64) $r2 > $r1 $r4
    + $r2 ($i64) $r28 0
;
||
    $st ($i64) [$r2 + 0] $r1
    + $r3 ($i64) $r0 -5
    $set $r5 0 999
    + $r6 ($i64) $r0 100
;
||
    + $r4 ($i64) $r0 $r5
;
||
    $cmov ? ($i64) $r3 > $r4 $r6
    + $r5 ($i64) $r28 0
;
||
    $st ($i64) [$r5 + 8] $r4
    + $r6 ($i64) $r0 -5
    $set $r8 0 999
    + $r9 ($i64) $r0 100
;
||
    + $r7 ($i64) $r0 $r8
;
||
    $cmov ? ($i64) $r6 < $r7 $r9
    + $r8 ($i64) $r28 0
;
||
    $st ($i64) [$r8 + 16] $r7
    + $r10 ($i64) $r0 5
    $set $r11 0 999
    + $r12 ($i64) $r0 100
;
||
    + $r9 ($i64) $r0 $r11
;
||
    $cmov ? ($i64) $r10 < $r9 $r12
    + $r10 ($i64) $r28 0
;
||
    $st ($i64) [$r10 + 24] $r9
    + $r12 ($i64) $r0 0
    $set $r13 0 999
    + $r14 ($i64) $r0 100
;
||
    + $r11 ($i64) $r0 $r13
;
||
    $cmov ? ($i64) $r12 == $r11 $r14
    + $r12 ($i64) $r28 0
;
||
    $st ($i64) [$r12 + 32] $r11
    + $r14 ($i64) $r0 5
    $set $r15 0 999
    + $r16 ($i64) $r0 100
;
||
    + $r13 ($i64) $r0 $r15
;
||
    $cmov ? ($i64) $r14 == $r13 $r16
    + $r14 ($i64) $r28 0
;
||
    $st ($i64) [$r14 + 40] $r13
    + $r16 ($i64) $r0 5
    $set $r17 0 999
    + $r18 ($i64) $r0 100
;
||
    + $r15 ($i64) $r0 $r17
;
||
    $cmov ? ($i64) $r16 != $r15 $r18
    + $r16 ($i64) $r28 0
;
||
    $st ($i64) [$r16 + 48] $r15
    + $r18 ($i64) $r0 0
    $set $r19 0 999
    + $r20 ($i64) $r0 100
;
||
    + $r17 ($i64) $r0 $r19
;
||
    $cmov ? ($i64) $r18 != $r17 $r20
    + $r18 ($i64) $r28 0
;
||
    $st ($i64) [$r18 + 56] $r17
    + $r20 ($i64) $r0 0
    $set $r21 0 999
    + $r22 ($i64) $r0 100
;
||
    + $r19 ($i64) $r0 $r21
;
||
    $cmov ? ($i64) $r20 >= $r19 $r22
    + $r20 ($i64) $r28 0
;
||
    $st ($i64) [$r20 + 64] $r19
    + $r22 ($i64) $r0 5
    $set $r23 0 999
    + $r24 ($i64) $r0 100
;
||
    + $r21 ($i64) $r0 $r23
;
||
    $cmov ? ($i64) $r22 >= $r21 $r24
    + $r22 ($i64) $r28 0
;
||
    $st ($i64) [$r22 + 72] $r21
    + $r23 ($i64) $r0 -5
    $set $r25 0 999
    + $r29 ($i64) $r0 100
;
||
    + $r24 ($i64) $r0 $r25
;
||
    $cmov ? ($i64) $r23 >= $r24 $r29
    + $r25 ($i64) $r28 0
;
||
    $st ($i64) [$r25 + 80] $r24
    + $r30 ($i64) $r0 0
    $set $r31 0 999
    + $r2 ($i64) $r0 100
;
||
    + $r29 ($i64) $r0 $r31
;
||
    $cmov ? ($i64) $r30 <= $r29 $r2
    + $r30 ($i64) $r28 0
;
||
    $st ($i64) [$r30 + 88] $r29
    + $r31 ($i64) $r0 -5
    $set $r1 0 999
    + $r3 ($i64) $r0 100
;
||
    + $r2 ($i64) $r0 $r1
;
||
    $cmov ? ($i64) $r31 <= $r2 $r3
    + $r1 ($i64) $r28 0
;
||
    $st ($i64) [$r1 + 96] $r2
    + $r5 ($i64) $r0 5
    $set $r4 0 999
    + $r6 ($i64) $r0 100
;
||
    + $r3 ($i64) $r0 $r4
;
||
    $cmov ? ($i64) $r5 <= $r3 $r6
    + $r5 ($i64) $r28 0
;
||
    $st ($i64) [$r5 + 104] $r3
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
