||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 808
;
||
    - $r27 ($i64) $r27 $r1
    + $r2 ($i64) $r0 1
    + $r3 ($i64) $r0 2
    + $r4 ($i64) $r0 3
