// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
add4:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 840
;
||
    - $r27 ($i64) $r27 $r1
    $st ($i32) [$r26 + -8] $r2
    $st ($i32) [$r26 + -16] $r3
    $st ($i32) [$r26 + -24] $r4
    $st ($i32) [$r26 + -32] $r5
    + $r1 ($i64) $r26 -8
;
||
    $ld ($i32) $r2 [$r1 + 0]
    + $r3 ($i64) $r26 -16
;
||
    $ld ($i32) $r4 [$r3 + 0]
;
||
    + $r5 ($i64) $r2 $r4
    + $r6 ($i64) $r26 -24
;
||
    $ld ($i32) $r7 [$r6 + 0]
;
||
    + $r8 ($i64) $r5 $r7
    + $r9 ($i64) $r26 -32
;
||
    $ld ($i32) $r10 [$r9 + 0]
;
||
    + $r11 ($i64) $r8 $r10
;
||
    + $r1 ($i64) $r0 $r11
    ? ($i64) $r0 == $goto add4_epilogue
;
add4_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
level_c:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 816
;
||
    - $r27 ($i64) $r27 $r1
    $st ($i32) [$r26 + -8] $r2
    + $r1 ($i64) $r26 -8
;
||
    $ld ($i32) $r2 [$r1 + 0]
;
||
    * $r3 ($i64) $r2 2
;
||
    + $r1 ($i64) $r0 $r3
    ? ($i64) $r0 == $goto level_c_epilogue
;
level_c_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
level_b:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 816
;
||
    - $r27 ($i64) $r27 $r1
    $st ($i32) [$r26 + -8] $r2
    + $r1 ($i64) $r26 -8
;
||
    $ld ($i32) $r2 [$r1 + 0]
;
||
    $st ($i64) [$r26 + -88] $r2
;
||
    $ld ($i64) $r2 [$r26 + -88]
    $call level_c
;
||
    + $r3 ($i64) $r0 $r1
    $ld ($i64) $r2 [$r26 + -88]
;
||
    + $r4 ($i64) $r3 1
;
||
    + $r1 ($i64) $r0 $r4
    ? ($i64) $r0 == $goto level_b_epilogue
;
level_b_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
level_a:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 816
;
||
    - $r27 ($i64) $r27 $r1
    $st ($i32) [$r26 + -8] $r2
    + $r1 ($i64) $r26 -8
;
||
    $ld ($i32) $r2 [$r1 + 0]
;
||
    $st ($i64) [$r26 + -88] $r2
;
||
    $ld ($i64) $r2 [$r26 + -88]
    $call level_b
;
||
    + $r3 ($i64) $r0 $r1
    $ld ($i64) $r2 [$r26 + -88]
;
||
    + $r4 ($i64) $r3 1
;
||
    + $r1 ($i64) $r0 $r4
    ? ($i64) $r0 == $goto level_a_epilogue
;
level_a_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
fact_rec:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 816
;
||
    - $r27 ($i64) $r27 $r1
    $st ($i32) [$r26 + -8] $r2
    + $r1 ($i64) $r26 -8
;
||
    $ld ($i32) $r2 [$r1 + 0]
    + $r3 ($i64) $r0 1
;
||
    - $r4 ($i64) $r3 $r2
;
||
    ? ($i64) $r4 >= $goto if_t_1
;
||
    ? ($i64) $r0 == $goto if_e_2
;
if_t_1:
||
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto fact_rec_epilogue
;
if_e_2:
||
    + $r3 ($i64) $r26 -8
;
||
    $ld ($i32) $r4 [$r3 + 0]
    + $r5 ($i64) $r26 -8
;
||
    $ld ($i32) $r6 [$r5 + 0]
;
||
    - $r7 ($i64) $r6 1
    $st ($i64) [$r26 + -88] $r4
;
||
    $st ($i64) [$r26 + -96] $r7
;
||
    $ld ($i64) $r2 [$r26 + -96]
    $call fact_rec
;
||
    + $r8 ($i64) $r0 $r1
    $ld ($i64) $r4 [$r26 + -88]
    $ld ($i64) $r7 [$r26 + -96]
;
||
    * $r9 ($i64) $r4 $r8
;
||
    + $r1 ($i64) $r0 $r9
    ? ($i64) $r0 == $goto fact_rec_epilogue
;
fact_rec_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
fib_rec:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 816
;
||
    - $r27 ($i64) $r27 $r1
    $st ($i32) [$r26 + -8] $r2
    + $r1 ($i64) $r26 -8
;
||
    $ld ($i32) $r2 [$r1 + 0]
    + $r3 ($i64) $r0 1
;
||
    - $r4 ($i64) $r3 $r2
;
||
    ? ($i64) $r4 >= $goto if_t_3
;
||
    ? ($i64) $r0 == $goto if_e_4
;
if_t_3:
||
    + $r3 ($i64) $r26 -8
;
||
    $ld ($i32) $r4 [$r3 + 0]
;
||
    + $r1 ($i64) $r0 $r4
    ? ($i64) $r0 == $goto fib_rec_epilogue
;
if_e_4:
||
    + $r5 ($i64) $r26 -8
;
||
    $ld ($i32) $r6 [$r5 + 0]
;
||
    - $r7 ($i64) $r6 1
;
||
    $st ($i64) [$r26 + -88] $r7
;
||
    $ld ($i64) $r2 [$r26 + -88]
    $call fib_rec
;
||
    + $r8 ($i64) $r0 $r1
    $ld ($i64) $r7 [$r26 + -88]
    + $r9 ($i64) $r26 -8
;
||
    $ld ($i32) $r10 [$r9 + 0]
;
||
    - $r11 ($i64) $r10 2
    $st ($i64) [$r26 + -88] $r8
;
||
    $st ($i64) [$r26 + -96] $r11
;
||
    $ld ($i64) $r2 [$r26 + -96]
    $call fib_rec
;
||
    + $r12 ($i64) $r0 $r1
    $ld ($i64) $r8 [$r26 + -88]
    $ld ($i64) $r11 [$r26 + -96]
;
||
    + $r13 ($i64) $r8 $r12
;
||
    + $r1 ($i64) $r0 $r13
    ? ($i64) $r0 == $goto fib_rec_epilogue
;
fib_rec_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 808
;
||
    - $r27 ($i64) $r27 $r1
    + $r2 ($i64) $r0 1
    + $r3 ($i64) $r0 2
    + $r4 ($i64) $r0 3
    + $r5 ($i64) $r0 4
;
||
    $call add4
;
||
    + $r1 ($i64) $r0 $r1
    + $r2 ($i64) $r28 0
;
||
    $st ($i64) [$r2 + 0] $r1
;
||
    + $r2 ($i64) $r0 5
    $call level_a
;
||
    + $r3 ($i64) $r0 $r1
    + $r4 ($i64) $r28 0
;
||
    $st ($i64) [$r4 + 8] $r3
    + $r2 ($i64) $r0 5
    $call fact_rec
;
||
    + $r5 ($i64) $r0 $r1
    + $r6 ($i64) $r28 0
;
||
    $st ($i64) [$r6 + 16] $r5
    + $r2 ($i64) $r0 1
    $call fact_rec
;
||
    + $r7 ($i64) $r0 $r1
    + $r8 ($i64) $r28 0
;
||
    $st ($i64) [$r8 + 24] $r7
    + $r2 ($i64) $r0 6
    $call fact_rec
;
||
    + $r9 ($i64) $r0 $r1
    + $r10 ($i64) $r28 0
;
||
    $st ($i64) [$r10 + 32] $r9
    + $r2 ($i64) $r0 0
    $call fib_rec
;
||
    + $r11 ($i64) $r0 $r1
    + $r12 ($i64) $r28 0
;
||
    $st ($i64) [$r12 + 40] $r11
    + $r2 ($i64) $r0 1
    $call fib_rec
;
||
    + $r13 ($i64) $r0 $r1
    + $r14 ($i64) $r28 0
;
||
    $st ($i64) [$r14 + 48] $r13
    + $r2 ($i64) $r0 10
    $call fib_rec
;
||
    + $r15 ($i64) $r0 $r1
    + $r16 ($i64) $r28 0
;
||
    $st ($i64) [$r16 + 56] $r15
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
