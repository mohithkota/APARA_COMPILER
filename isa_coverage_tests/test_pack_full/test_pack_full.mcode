// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 840
;
||
    - $r27 ($i64) $r27 $r1
    $set $r2 0 48879
    $set $r3 0 57005
;
||
    + $r4 ($i64) $r0 $r2
    + $r5 ($i64) $r0 $r3
;
||
    $pack 32 $r1 16 $r4
    + $r2 ($i64) $r26 -8
;
||
    $st ($i64) [$r2 + 0] $r1
    + $r3 ($i64) $r26 -8
;
||
    $ld ($i64) $r4 [$r3 + 0]
    $set $r5 0 57005
    $set $r6 0 48879
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
;
||
    - $r6 ($i64) $r4 $r5
;
||
    ? ($i64) $r6 != $goto if_t_1
;
||
    ? ($i64) $r0 == $goto if_e_2
;
if_t_1:
||
    + $r5 ($i64) $r0 -1
;
||
    + $r1 ($i64) $r0 $r5
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_2:
||
    $set $r7 0 22136
    $set $r8 0 4660
;
||
    << $r8 ($i64) $r8 16
;
||
    | $r7 ($i64) $r7 $r8
    $set $r8 0 57072
    $set $r9 0 39612
;
||
    << $r9 ($i64) $r9 16
;
||
    | $r8 ($i64) $r8 $r9
    + $r2 ($i64) $r0 $r7
;
||
    + $r3 ($i64) $r0 $r8
;
||
    $pack 64 $r6 32 $r2
    + $r7 ($i64) $r26 -16
;
||
    $st ($i64) [$r7 + 0] $r6
    + $r8 ($i64) $r26 -16
;
||
    $ld ($i64) $r2 [$r8 + 0]
    $set $r3 0 57072
    $set $r9 0 39612
    $set $r10 0 22136
    $set $r11 0 4660
;
||
    << $r11 ($i64) $r11 16
;
||
    | $r10 ($i64) $r10 $r11
;
||
    << $r10 ($i64) $r10 16
;
||
    | $r9 ($i64) $r9 $r10
;
||
    << $r9 ($i64) $r9 16
;
||
    | $r3 ($i64) $r3 $r9
;
||
    - $r9 ($i64) $r2 $r3
;
||
    ? ($i64) $r9 != $goto if_t_3
;
||
    ? ($i64) $r0 == $goto if_e_4
;
if_t_3:
||
    + $r3 ($i64) $r0 -2
;
||
    + $r1 ($i64) $r0 $r3
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_4:
||
    $set $r10 0 22136
    $set $r11 0 4660
;
||
    << $r11 ($i64) $r11 16
;
||
    | $r10 ($i64) $r10 $r11
    $set $r11 0 43690
    $set $r12 0 43690
;
||
    << $r12 ($i64) $r12 16
;
||
    | $r11 ($i64) $r11 $r12
    + $r2 ($i64) $r0 $r10
;
||
    + $r3 ($i64) $r0 $r11
;
||
    $pack 32 $r9 32 $r2
    + $r10 ($i64) $r26 -24
;
||
    $st ($i64) [$r10 + 0] $r9
    + $r11 ($i64) $r26 -24
;
||
    $ld ($i64) $r2 [$r11 + 0]
    $set $r3 0 22136
    $set $r12 0 4660
;
||
    << $r12 ($i64) $r12 16
;
||
    | $r3 ($i64) $r3 $r12
;
||
    - $r12 ($i64) $r2 $r3
;
||
    ? ($i64) $r12 != $goto if_t_5
;
||
    ? ($i64) $r0 == $goto if_e_6
;
if_t_5:
||
    + $r3 ($i64) $r0 -3
;
||
    + $r1 ($i64) $r0 $r3
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_6:
||
    $set $r13 0 52719
    $set $r14 0 35243
    $set $r15 0 17767
    + $r16 ($i64) $r0 291
;
||
    << $r16 ($i64) $r16 16
;
||
    | $r15 ($i64) $r15 $r16
;
||
    << $r15 ($i64) $r15 16
;
||
    | $r14 ($i64) $r14 $r15
;
||
    << $r14 ($i64) $r14 16
;
||
    | $r13 ($i64) $r13 $r14
    $set $r14 0 21845
    $set $r15 0 21845
    $set $r16 0 21845
    $set $r17 0 21845
;
||
    << $r17 ($i64) $r17 16
;
||
    | $r16 ($i64) $r16 $r17
;
||
    << $r16 ($i64) $r16 16
;
||
    | $r15 ($i64) $r15 $r16
;
||
    << $r15 ($i64) $r15 16
;
||
    | $r14 ($i64) $r14 $r15
    + $r2 ($i64) $r0 $r13
;
||
    + $r3 ($i64) $r0 $r14
;
||
    $pack 64 $r12 64 $r2
    + $r13 ($i64) $r26 -32
;
||
    $st ($i64) [$r13 + 0] $r12
    + $r14 ($i64) $r26 -32
;
||
    $ld ($i64) $r2 [$r14 + 0]
    $set $r3 0 52719
    $set $r15 0 35243
    $set $r16 0 17767
    + $r17 ($i64) $r0 291
;
||
    << $r17 ($i64) $r17 16
;
||
    | $r16 ($i64) $r16 $r17
;
||
    << $r16 ($i64) $r16 16
;
||
    | $r15 ($i64) $r15 $r16
;
||
