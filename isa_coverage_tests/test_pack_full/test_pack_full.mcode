;
||
    - $r15 ($i64) $r2 $r3
;
||
    ? ($i64) $r15 != $goto if_t_7
;
||
    ? ($i64) $r0 == $goto if_e_8
;
if_t_7:
||
    + $r3 ($i64) $r0 -4
;
||
    + $r1 ($i64) $r0 $r3
    ? ($i64) $r0 == $goto main_epilogue
;
if_e_8:
||
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
