// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 808
;
||
    - $r27 ($i64) $r27 $r1
    $set $r2 0 48879
    $set $r3 0 57005
;
||
    + $r4 ($i64) $r0 $r2
    + $r5 ($i64) $r0 $r3
;
||
    $pack 32 $r1 16 $r4
    + $r2 ($i64) $r28 0
;
||
    $st ($i64) [$r2 + 0] $r1
    $set $r4 0 22136
    $set $r5 0 4660
;
||
    << $r5 ($i64) $r5 16
;
||
    | $r4 ($i64) $r4 $r5
    $set $r5 0 57072
    $set $r6 0 39612
;
||
    << $r6 ($i64) $r6 16
;
||
    | $r5 ($i64) $r5 $r6
    + $r6 ($i64) $r0 $r4
;
||
    + $r7 ($i64) $r0 $r5
;
||
    $pack 64 $r3 32 $r6
    + $r4 ($i64) $r28 0
;
||
    $st ($i64) [$r4 + 8] $r3
    $set $r6 0 22136
    $set $r7 0 4660
;
||
    << $r7 ($i64) $r7 16
;
||
    | $r6 ($i64) $r6 $r7
    $set $r7 0 43690
    $set $r8 0 43690
;
||
    << $r8 ($i64) $r8 16
;
||
    | $r7 ($i64) $r7 $r8
    + $r2 ($i64) $r0 $r6
;
||
    + $r3 ($i64) $r0 $r7
;
||
    $pack 32 $r5 32 $r2
    + $r6 ($i64) $r28 0
;
||
    $st ($i64) [$r6 + 16] $r5
    $set $r2 0 52719
    $set $r3 0 35243
    $set $r8 0 17767
    + $r9 ($i64) $r0 291
;
||
    << $r9 ($i64) $r9 16
;
||
    | $r8 ($i64) $r8 $r9
;
||
    << $r8 ($i64) $r8 16
;
||
    | $r3 ($i64) $r3 $r8
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
    $set $r3 0 21845
    $set $r8 0 21845
    $set $r9 0 21845
    $set $r10 0 21845
;
||
    << $r10 ($i64) $r10 16
;
||
    | $r9 ($i64) $r9 $r10
;
||
    << $r9 ($i64) $r9 16
;
||
    | $r8 ($i64) $r8 $r9
;
||
    << $r8 ($i64) $r8 16
;
||
    | $r3 ($i64) $r3 $r8
    + $r4 ($i64) $r0 $r2
;
||
    + $r5 ($i64) $r0 $r3
;
||
    $pack 64 $r7 64 $r4
    + $r2 ($i64) $r28 0
;
||
    $st ($i64) [$r2 + 24] $r7
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
