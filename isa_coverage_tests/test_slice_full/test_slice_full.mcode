// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 824
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r26 -8
    $set $r2 0 47768
    $set $r3 0 65244
;
||
    << $r3 ($i64) $r3 16
;
||
    | $r2 ($i64) $r2 $r3
;
||
    $st ($i64) [$r1 + 0] $r2
;
||
    + $r2 ($i64) $r26 -8
;
||
    $ld ($i64) $r3 [$r2 + 0]
;
||
    $slice $r4 3 0 $r3
    + $r5 ($i64) $r28 0
;
||
    $st ($i64) [$r5 + 0] $r4
    + $r6 ($i64) $r26 -8
;
||
    $ld ($i64) $r7 [$r6 + 0]
;
||
    $slice $r8 7 4 $r7
    + $r9 ($i64) $r28 0
;
||
    $st ($i64) [$r9 + 8] $r8
    + $r10 ($i64) $r26 -8
;
||
    $ld ($i64) $r11 [$r10 + 0]
;
||
    $slice $r12 7 0 $r11
    + $r13 ($i64) $r28 0
;
||
    $st ($i64) [$r13 + 16] $r12
    + $r14 ($i64) $r26 -8
;
||
    $ld ($i64) $r15 [$r14 + 0]
;
||
    $slice $r16 15 8 $r15
    + $r17 ($i64) $r28 0
;
||
    $st ($i64) [$r17 + 24] $r16
    + $r18 ($i64) $r26 -8
;
||
    $ld ($i64) $r19 [$r18 + 0]
;
||
    $slice $r20 31 24 $r19
    + $r21 ($i64) $r28 0
;
||
    $st ($i64) [$r21 + 32] $r20
    + $r22 ($i64) $r26 -8
;
||
    $ld ($i64) $r23 [$r22 + 0]
;
||
    $slice $r24 15 0 $r23
    + $r25 ($i64) $r28 0
;
||
    $st ($i64) [$r25 + 40] $r24
    + $r29 ($i64) $r26 -8
;
||
    $ld ($i64) $r30 [$r29 + 0]
;
||
    $slice $r31 31 16 $r30
    + $r1 ($i64) $r28 0
;
||
    $st ($i64) [$r1 + 48] $r31
    + $r2 ($i64) $r26 -8
;
||
    $ld ($i64) $r3 [$r2 + 0]
;
||
    $slice $r5 10 3 $r3
    + $r4 ($i64) $r28 0
;
||
    $st ($i64) [$r4 + 56] $r5
    + $r6 ($i64) $r26 -16
    $set $r7 0 57072
    $set $r9 0 39612
    $set $r8 0 22136
    $set $r10 0 4660
;
||
    << $r10 ($i64) $r10 16
;
||
    | $r8 ($i64) $r8 $r10
;
||
    << $r8 ($i64) $r8 16
;
||
    | $r9 ($i64) $r9 $r8
;
||
    << $r9 ($i64) $r9 16
;
||
    | $r7 ($i64) $r7 $r9
;
||
    $st ($i64) [$r6 + 0] $r7
;
||
    + $r7 ($i64) $r26 -16
;
||
    $ld ($i64) $r9 [$r7 + 0]
;
||
    $slice $r8 31 0 $r9
    + $r10 ($i64) $r28 0
;
||
    $st ($i64) [$r10 + 64] $r8
    + $r11 ($i64) $r26 -16
;
||
    $ld ($i64) $r13 [$r11 + 0]
;
||
    $slice $r12 63 32 $r13
    + $r14 ($i64) $r28 0
;
||
    $st ($i64) [$r14 + 72] $r12
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
