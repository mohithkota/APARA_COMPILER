// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 856
;
||
    - $r27 ($i64) $r27 $r1
    + $r1 ($i64) $r0 -1
    + $r2 ($i64) $r26 -8
;
||
    $st ($i64) [$r2 + 0] $r1
    + $r3 ($i64) $r26 -8
;
||
    $ld ($i64) $r4 [$r3 + 0]
;
||
    $cast ($i64) $r5 ($i8) $r4
    + $r6 ($i64) $r28 0
;
||
    $st ($i64) [$r6 + 0] $r5
    + $r7 ($i64) $r26 -8
;
||
    $ld ($i64) $r8 [$r7 + 0]
;
||
    $cast ($i64) $r9 ($u8) $r8
    + $r10 ($i64) $r28 0
;
||
    $st ($i64) [$r10 + 8] $r9
    + $r11 ($i64) $r26 -16
    + $r12 ($i64) $r0 200
;
||
    $st ($i64) [$r11 + 0] $r12
;
||
    + $r12 ($i64) $r26 -16
;
||
    $ld ($i64) $r13 [$r12 + 0]
;
||
    $cast ($i64) $r14 ($i8) $r13
    + $r15 ($i64) $r28 0
;
||
    $st ($i64) [$r15 + 16] $r14
    + $r16 ($i64) $r26 -16
;
||
    $ld ($i64) $r17 [$r16 + 0]
;
||
    $cast ($i64) $r18 ($u8) $r17
    + $r19 ($i64) $r28 0
;
||
    $st ($i64) [$r19 + 24] $r18
    + $r20 ($i64) $r26 -8
;
||
    $ld ($i64) $r21 [$r20 + 0]
;
||
    $cast ($i64) $r22 ($i16) $r21
    + $r23 ($i64) $r28 0
;
||
    $st ($i64) [$r23 + 32] $r22
    + $r24 ($i64) $r26 -8
;
||
    $ld ($i64) $r25 [$r24 + 0]
;
||
    $cast ($i64) $r29 ($u16) $r25
    + $r30 ($i64) $r28 0
;
||
    $st ($i64) [$r30 + 40] $r29
    + $r31 ($i64) $r26 -24
    $set $r2 0 40000
;
||
    $st ($i64) [$r31 + 0] $r2
;
||
    + $r2 ($i64) $r26 -24
;
||
    $ld ($i64) $r1 [$r2 + 0]
;
||
    $cast ($i64) $r3 ($i16) $r1
    + $r4 ($i64) $r28 0
;
||
    $st ($i64) [$r4 + 48] $r3
    + $r6 ($i64) $r26 -24
;
||
    $ld ($i64) $r5 [$r6 + 0]
;
||
    $cast ($i64) $r7 ($u16) $r5
    + $r8 ($i64) $r28 0
;
||
    $st ($i64) [$r8 + 56] $r7
    + $r10 ($i64) $r26 -8
;
||
    $ld ($i64) $r9 [$r10 + 0]
;
||
    $cast ($i64) $r11 ($i32) $r9
    + $r12 ($i64) $r28 0
;
||
    $st ($i64) [$r12 + 64] $r11
    + $r13 ($i64) $r26 -8
;
||
    $ld ($i64) $r15 [$r13 + 0]
;
||
    $cast ($i64) $r14 ($u32) $r15
    + $r16 ($i64) $r28 0
;
||
    $st ($i64) [$r16 + 72] $r14
    + $r17 ($i64) $r26 -32
    $set $r19 0 24064
    $set $r18 0 45776
;
||
    << $r18 ($i64) $r18 16
;
||
    | $r19 ($i64) $r19 $r18
;
||
    $st ($i64) [$r17 + 0] $r19
;
||
    + $r19 ($i64) $r26 -32
;
||
    $ld ($i64) $r18 [$r19 + 0]
;
||
    $cast ($i64) $r20 ($i32) $r18
    + $r21 ($i64) $r28 0
;
||
    $st ($i64) [$r21 + 80] $r20
    + $r23 ($i64) $r26 -32
;
||
    $ld ($i64) $r22 [$r23 + 0]
;
||
    $cast ($i64) $r24 ($u32) $r22
    + $r25 ($i64) $r28 0
;
||
    $st ($i64) [$r25 + 88] $r24
    + $r30 ($i64) $r26 -16
;
||
    $ld ($i64) $r29 [$r30 + 0]
;
||
    $cast ($i64) $r31 ($i8) $r29
    + $r2 ($i64) $r26 -40
;
||
    $st ($i8) [$r2 + 0] $r31
    + $r1 ($i64) $r26 -16
;
||
    $ld ($i64) $r4 [$r1 + 0]
;
||
    $cast ($i64) $r3 ($u8) $r4
    + $r6 ($i64) $r26 -48
;
||
    $st ($i8) [$r6 + 0] $r3
    + $r5 ($i64) $r26 -40
;
||
    $ld ($i8) $r8 [$r5 + 0]
    + $r7 ($i64) $r28 0
;
||
    $st ($i64) [$r7 + 96] $r8
    + $r10 ($i64) $r26 -48
;
||
    $ld ($u8) $r9 [$r10 + 0]
    + $r12 ($i64) $r28 0
;
||
    $st ($i64) [$r12 + 104] $r9
    + $r1 ($i64) $r0 1
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
