||
    $st ($i64) [$r11 + 0] $r6
    + $r8 ($i64) $r26 -32
    + $r10 ($i64) $r0 0
;
||
    $st ($i32) [$r8 + 0] $r10
;
fc_1:
||
    + $r10 ($i64) $r26 -32
;
||
    $ld ($i32) $r12 [$r10 + 0]
    + $r14 ($i64) $r0 5
;
||
    - $r13 ($i64) $r14 $r12
;
||
    ? ($i64) $r13 > $goto fb_2
;
||
    ? ($i64) $r0 == $goto fe_4
;
fb_2:
||
    + $r14 ($i64) $r26 -24
;
||
    $ld ($i64) $r13 [$r14 + 0]
    + $r15 ($i64) $r26 -16
