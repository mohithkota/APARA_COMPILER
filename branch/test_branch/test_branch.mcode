// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 10
;
||
    $st ($i64) [$r28 + 0] $r30
;
||
    + $r30 ($i64) $r0 20
;
||
    $st ($i64) [$r28 + 8] $r30
;
||
    + $r30 ($i64) $r0 10
;
||
    $st ($i64) [$r28 + 16] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 24] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 32] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 40] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 48] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 56] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 64] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 808
;
||
    - $r27 ($i64) $r27 $r1
    $ld ($i64) $r1 [$r28 + 0]
    $ld ($i64) $r2 [$r28 + 8]
;
||
    - $r3 ($i64) $r2 $r1
;
||
    ? ($i64) $r3 > $goto if_t_1
;
||
    ? ($i64) $r0 == $goto if_f_3
;
if_t_1:
||
    + $r3 ($i64) $r0 1
;
||
    $st ($i64) [$r28 + 24] $r3
    ? ($i64) $r0 == $goto if_e_2
;
if_f_3:
||
    + $r3 ($i64) $r0 99
;
||
    $st ($i64) [$r28 + 24] $r3
;
if_e_2:
||
    $ld ($i64) $r3 [$r28 + 0]
    $ld ($i64) $r4 [$r28 + 8]
;
||
    - $r5 ($i64) $r3 $r4
;
||
    ? ($i64) $r5 > $goto if_t_4
;
||
    ? ($i64) $r0 == $goto if_f_6
;
if_t_4:
||
    + $r5 ($i64) $r0 1
;
||
    $st ($i64) [$r28 + 32] $r5
    ? ($i64) $r0 == $goto if_e_5
;
if_f_6:
||
    + $r5 ($i64) $r0 99
;
||
    $st ($i64) [$r28 + 32] $r5
;
if_e_5:
||
    $ld ($i64) $r5 [$r28 + 0]
    $ld ($i64) $r6 [$r28 + 16]
;
||
    - $r7 ($i64) $r5 $r6
;
||
    ? ($i64) $r7 == $goto if_t_7
;
||
    ? ($i64) $r0 == $goto if_f_9
;
if_t_7:
||
    + $r7 ($i64) $r0 1
;
||
    $st ($i64) [$r28 + 40] $r7
    ? ($i64) $r0 == $goto if_e_8
;
if_f_9:
||
    + $r7 ($i64) $r0 99
;
||
    $st ($i64) [$r28 + 40] $r7
;
if_e_8:
||
    $ld ($i64) $r7 [$r28 + 0]
    $ld ($i64) $r8 [$r28 + 8]
;
||
    - $r9 ($i64) $r7 $r8
;
||
    ? ($i64) $r9 != $goto if_t_10
;
||
    ? ($i64) $r0 == $goto if_f_12
;
if_t_10:
||
    + $r9 ($i64) $r0 1
;
||
    $st ($i64) [$r28 + 48] $r9
    ? ($i64) $r0 == $goto if_e_11
;
if_f_12:
||
    + $r9 ($i64) $r0 99
;
||
    $st ($i64) [$r28 + 48] $r9
;
if_e_11:
||
    $ld ($i64) $r9 [$r28 + 0]
    $ld ($i64) $r10 [$r28 + 16]
;
||
    - $r11 ($i64) $r9 $r10
;
||
    ? ($i64) $r11 >= $goto if_t_13
;
||
    ? ($i64) $r0 == $goto if_f_15
;
if_t_13:
||
    + $r11 ($i64) $r0 1
;
||
    $st ($i64) [$r28 + 56] $r11
    ? ($i64) $r0 == $goto if_e_14
;
if_f_15:
||
    + $r11 ($i64) $r0 99
;
||
    $st ($i64) [$r28 + 56] $r11
;
if_e_14:
||
    $ld ($i64) $r11 [$r28 + 0]
    $ld ($i64) $r12 [$r28 + 8]
;
||
    - $r13 ($i64) $r12 $r11
;
||
    ? ($i64) $r13 >= $goto if_t_16
;
||
    ? ($i64) $r0 == $goto if_f_18
;
if_t_16:
||
    + $r13 ($i64) $r0 1
;
||
    $st ($i64) [$r28 + 64] $r13
    ? ($i64) $r0 == $goto if_e_17
;
if_f_18:
||
    + $r13 ($i64) $r0 99
;
||
    $st ($i64) [$r28 + 64] $r13
;
if_e_17:
||
    $ld ($i64) $r13 [$r28 + 24]
;
||
    + $r1 ($i64) $r0 $r13
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
