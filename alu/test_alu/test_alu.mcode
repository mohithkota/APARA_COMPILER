// ── APARA startup (APARA C Compiler v6: 28-reg + spilling) ──────────────────
// Fixed: $r0=ZERO $r28=GBASE=0x400  Reserved: $r26=FP $r27=SP
// Pool:  $r1-$r25 $r29-$r31  (28 registers, all recycled dynamically)
apara_start:
||
    $set $r28 0 1024
    $set $r27 0 32760
;
||
    + $r26 ($i64) $r0 $r27
    + $r30 ($i64) $r0 10
;
||
    $st ($i64) [$r28 + 0] $r30
;
||
    + $r30 ($i64) $r0 3
;
||
    $st ($i64) [$r28 + 8] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 16] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 24] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 32] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 40] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 48] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 56] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 64] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 72] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 80] $r30
;
||
    + $r30 ($i64) $r0 0
;
||
    $st ($i64) [$r28 + 88] $r30
    $call main
;
||
    $halt
;
main:
||
    $st ($i64) [$r27 + 0] $r26
;
||
    + $r26 ($i64) $r0 $r27
    $set $r1 0 808
;
||
    - $r27 ($i64) $r27 $r1
    $ld ($i64) $r1 [$r28 + 0]
    $ld ($i64) $r2 [$r28 + 8]
;
||
    + $r3 ($i64) $r1 $r2
;
||
    $st ($i64) [$r28 + 16] $r3
    $ld ($i64) $r4 [$r28 + 0]
    $ld ($i64) $r5 [$r28 + 8]
;
||
    - $r6 ($i64) $r4 $r5
;
||
    $st ($i64) [$r28 + 24] $r6
    $ld ($i64) $r7 [$r28 + 0]
    $ld ($i64) $r8 [$r28 + 8]
;
||
    * $r9 ($i64) $r7 $r8
;
||
    $st ($i64) [$r28 + 32] $r9
    $ld ($i64) $r10 [$r28 + 0]
    $ld ($i64) $r11 [$r28 + 8]
;
||
    / $r12 ($i64) $r10 $r11
;
||
    $st ($i64) [$r28 + 40] $r12
    $ld ($i64) $r13 [$r28 + 0]
    $ld ($i64) $r14 [$r28 + 8]
;
||
    / $r16 ($i64) $r13 $r14
;
||
    * $r16 ($i64) $r16 $r14
;
||
    - $r15 ($i64) $r13 $r16
;
||
    $st ($i64) [$r28 + 48] $r15
    $ld ($i64) $r16 [$r28 + 0]
    $ld ($i64) $r17 [$r28 + 8]
;
||
    & $r18 ($i64) $r16 $r17
;
||
    $st ($i64) [$r28 + 56] $r18
    $ld ($i64) $r19 [$r28 + 0]
    $ld ($i64) $r20 [$r28 + 8]
;
||
    | $r21 ($i64) $r19 $r20
;
||
    $st ($i64) [$r28 + 64] $r21
    $ld ($i64) $r22 [$r28 + 0]
    $ld ($i64) $r23 [$r28 + 8]
;
||
    ^ $r24 ($i64) $r22 $r23
;
||
    $st ($i64) [$r28 + 72] $r24
    $ld ($i64) $r25 [$r28 + 0]
    $ld ($i64) $r29 [$r28 + 8]
;
||
    << $r30 ($i64) $r25 $r29
;
||
    $st ($i64) [$r28 + 80] $r30
    $ld ($i64) $r31 [$r28 + 0]
    $ld ($i64) $r1 [$r28 + 8]
;
||
    >> $r2 ($i64) $r31 $r1
;
||
    $st ($i64) [$r28 + 88] $r2
    $ld ($i64) $r3 [$r28 + 16]
;
||
    + $r1 ($i64) $r0 $r3
    ? ($i64) $r0 == $goto main_epilogue
;
main_epilogue:
||
    + $r27 ($i64) $r0 $r26
;
||
    $ld ($i64) $r26 [$r27 + 0]
    $return
;
